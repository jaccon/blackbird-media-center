<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Câmeras RTSP - Black Bird Media Center</title>
  <!-- Lightbox Gallery CSS -->
  <link rel="stylesheet" href="/css/lightbox.min.css">
  <style>
    @keyframes scanline {
      0% { transform: translateY(-100%); }
      100% { transform: translateY(100%); }
    }
    .scanline::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
      background-size: 100% 4px, 6px 100%;
      pointer-events: none;
    }
    .scanline-bar::before {
      content: '';
      position: absolute;
      width: 100%;
      height: 2px;
      background: rgba(124, 58, 237, 0.2);
      animation: scanline 6s linear infinite;
      pointer-events: none;
    }
  </style>
</head>
<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) (Bootstrap 5) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <!-- Modal Header -->
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <!-- Modal Body -->
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
          <div id="selectedFilesInfo" class="small text-secondary mt-3 p-3 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10 d-none" style="max-height: 110px; overflow-y: auto;"></div>
        </div>
        <!-- Modal Footer -->
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xl py-4 px-3">
    
    <!-- Cabeçalho de Controle -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
      <div>
        <h2 class="fs-4 fw-bold text-white font-outfit m-0">Câmeras RTSP</h2>
        <p class="text-secondary small m-0 mt-1">Gerencie e visualize streams de vídeo de segurança</p>
      </div>

      <div class="d-flex align-items-center gap-2">
        <button onclick="toggleAddCamModal()" class="btn btn-premium-primary border-0 d-flex align-items-center gap-2">
          <i class="bi bi-plus-circle"></i> Adicionar Câmera
        </button>
        <% if (isStreaming) { %>
          <a href="/cameras" class="btn btn-premium-secondary d-flex align-items-center gap-2 text-decoration-none">
            <i class="bi bi-grid"></i> Painel Geral
          </a>
        <% } else if (cameras.length > 0) { %>
          <a href="/rtsp-cams/streaming" class="btn btn-success d-flex align-items-center gap-2 text-decoration-none border-0" style="background-color: #10b981;">
            <i class="bi bi-play-circle"></i> Muro de Câmeras
          </a>
        <% } %>
      </div>
    </div>

    <!-- MODO STREAMING: Live Wall Split View -->
    <% if (isStreaming) { %>
      <% if (cameras.length === 0) { %>
        <div class="text-center py-5 rounded-3 border border-secondary border-opacity-10" style="background-color: rgba(15, 23, 42, 0.25);">
          <i class="bi bi-camera-video-off text-secondary block mb-3" style="font-size: 3rem;"></i>
          <h3 class="fs-5 fw-bold text-white font-outfit">Nenhuma câmera cadastrada</h3>
          <p class="text-secondary small mt-1 max-w-sm mx-auto mb-0">Adicione câmeras para iniciar o monitoramento ao vivo.</p>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% cameras.forEach((camera, index) => { %>
            <div class="col-12 col-md-6">
              <div class="card card-premium aspect-ratio ratio ratio-16x9 border-0 rounded-3 overflow-hidden scanline scanline-bar shadow-lg position-relative" style="background-color: #000 !important;">
                <!-- Overlay Superior: REC + Clock -->
                <div class="position-absolute top-0 start-0 end-0 d-flex justify-content-between align-items-center z-3 p-3 text-white select-none">
                  <div class="d-flex align-items-center gap-2 bg-dark bg-opacity-75 px-2.5 py-1 rounded border border-secondary border-opacity-10" style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
                    <span class="pulse-indicator m-0"></span>
                    <span class="text-danger small fw-bold tracking-wider">LIVE</span>
                  </div>
                  <div class="bg-dark bg-opacity-75 px-2.5 py-1 rounded border border-secondary border-opacity-10 text-secondary font-mono small time-display" style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
                    Carregando...
                  </div>
                </div>

                <!-- Simulação de Vídeo (Estética Cyberpunk) -->
                <div class="d-flex flex-column align-items-center justify-content-center bg-black bg-opacity-50 text-center p-4 h-100 w-100">
                  <!-- Ruído estático mockado com SVG/CSS -->
                  <div class="position-absolute inset-0 opacity-10 bg-repeat bg-center" style="background-image: url('data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%224%22 height=%224%22 viewBox=%220 0 4 4%22%3E%3Cpath fill=%22%23ffffff%22 opacity=%22.5%22 d=%22M1 0h1v1H1zm2 2h1v1H3zm-2 1h1v1H1z%22/%3E%3C/svg%3E');"></div>
                  <i class="bi bi-camera-video text-secondary text-opacity-25 mb-2" style="font-size: 3rem;"></i>
                  <div class="small font-mono text-secondary fw-semibold">STREAM FEED #<%= index + 1 %></div>
                  <div class="font-mono text-secondary mt-1 text-truncate max-w-75" style="font-size: 11px;"><%= camera.url %></div>
                </div>

                <!-- Overlay Inferior: Nome da Câmera -->
                <div class="position-absolute bottom-0 start-0 m-3 z-3 bg-dark bg-opacity-75 px-3 py-1.5 rounded-3 border border-secondary border-opacity-10 text-white font-outfit" style="backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); font-size: 13px;">
                  <%= camera.name %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>

    <!-- MODO PAINEL GERAL: Gerenciamento em Grid -->
    <% } else { %>
      <% if (cameras.length === 0) { %>
        <div class="text-center py-5 rounded-3 border border-secondary border-opacity-10" style="background-color: rgba(15, 23, 42, 0.25);">
          <i class="bi bi-camera-video text-secondary block mb-3" style="font-size: 3rem;"></i>
          <h3 class="fs-5 fw-bold text-white font-outfit">Nenhuma câmera monitorada</h3>
          <p class="text-secondary small mt-1 max-w-sm mx-auto mb-3">Cadastre streams RTSP para acompanhar imagens ao vivo de salas, portarias ou áreas de segurança.</p>
          <button onclick="toggleAddCamModal()" class="btn btn-premium-primary border-0 d-flex align-items-center gap-2 mx-auto">
            <i class="bi bi-plus-circle"></i> Adicionar Primeira Câmera
          </button>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% cameras.forEach((camera, index) => { %>
            <div class="col-12 col-md-6 col-lg-4">
              <div class="card card-premium">
                
                <!-- Feed Preview Mock -->
                <div class="ratio ratio-16x9 bg-black bg-opacity-75 d-flex flex-column align-items-center justify-content-center border-bottom border-secondary border-opacity-10">
                  <div class="d-flex flex-column align-items-center justify-content-center w-100 h-100">
                    <i class="bi bi-shield-check text-success text-opacity-40 mb-2" style="font-size: 2.5rem;"></i>
                    <span class="small fw-semibold text-success bg-success bg-opacity-10 border border-success border-opacity-25 px-2.5 py-0.5 rounded-pill d-flex align-items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
                      Conectado
                    </span>
                  </div>
                </div>

                <!-- Detalhes do Stream -->
                <div class="card-body p-4" style="min-height: 140px;">
                  <div>
                    <h4 class="card-title text-white font-outfit fw-bold fs-6 text-truncate mb-2"><%= camera.name %></h4>
                    <div class="small font-mono text-secondary bg-dark bg-opacity-50 p-2 rounded border border-secondary border-opacity-10 text-truncate" title="<%= camera.url %>">
                      <%= camera.url %>
                    </div>
                  </div>

                  <!-- Ações -->
                  <div class="d-flex align-items-center justify-content-between mt-4 pt-3 border-top border-secondary border-opacity-10">
                    <a href="/cameras?streaming=true" class="btn btn-sm btn-link text-decoration-none text-gradient fw-bold d-flex align-items-center gap-1 p-0">
                      Visualizar Stream
                      <i class="bi bi-arrow-right fs-6"></i>
                    </a>

                    <form action="/rtsp-cams/delete/<%= index %>" method="POST" class="m-0">
                      <button type="submit" class="btn btn-sm btn-link text-decoration-none text-danger fw-semibold d-flex align-items-center gap-1 p-0 cursor-pointer" onclick="return confirm('Tem certeza que deseja remover esta câmera?')">
                        <i class="bi bi-trash"></i>
                        Excluir
                      </button>
                    </form>
                  </div>
                </div>

              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    <% } %>

  </div>

  <!-- Modal Adicionar Câmera (Bootstrap 5) -->
  <div class="modal fade animate" id="addCameraModal" tabindex="-1" aria-labelledby="addCameraModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        
        <!-- Modal Header -->
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="addCameraModalLabel">Adicionar Câmera RTSP</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleAddCamModal()" aria-label="Close"></button>
        </div>
        
        <!-- Modal Form -->
        <form action="/rtsp-cams/add" method="POST" class="m-0">
          <div class="modal-body p-4">
            <div class="mb-3">
              <label for="cameraName" class="form-label text-uppercase text-secondary fw-semibold small tracking-wider mb-2">Nome da Câmera</label>
              <input type="text" id="cameraName" name="name" placeholder="Ex: Câmera Portaria" required
                     class="form-control input-premium">
            </div>
            
            <div class="mb-3">
              <label for="cameraUrl" class="form-label text-uppercase text-secondary fw-semibold small tracking-wider mb-2">URL RTSP</label>
              <input type="text" id="cameraUrl" name="url" placeholder="Ex: rtsp://user:pass@ip:554/stream" required
                     class="form-control input-premium">
            </div>
          </div>
          
          <!-- Modal Footer -->
          <div class="modal-footer modal-footer-premium border-0">
            <button type="button" class="btn btn-premium-secondary" onclick="toggleAddCamModal()">
              Cancelar
            </button>
            <button type="submit" class="btn btn-premium-primary border-0">
              Adicionar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/lightbox-plus-jquery.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    // Controle do Modal
    function toggleAddCamModal() {
      const modalEl = document.getElementById('addCameraModal');
      if (modalEl) {
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        if (modalEl.classList.contains('show')) {
          modal.hide();
        } else {
          modal.show();
        }
      }
    }

    // Monitor do relógio em tempo real no Modo Streaming
    <% if (isStreaming) { %>
      function updateClocks() {
        const now = new Date();
        const dateStr = now.toLocaleDateString('pt-BR');
        const timeStr = now.toLocaleTimeString('pt-BR');
        const displays = document.querySelectorAll('.time-display');
        displays.forEach(display => {
          display.textContent = `${dateStr} ${timeStr}`;
        });
      }
      setInterval(updateClocks, 1000);
      updateClocks();
    <% } %>

    // Monitoramento do Input de Upload (para compatibilidade com header)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
      fileInput.addEventListener('change', function(e) {
        const info = document.getElementById('selectedFilesInfo');
        if (this.files && this.files.length > 0) {
          info.classList.remove('d-none');
          info.innerHTML = `<strong>Selecionados (${this.files.length}):</strong><ul class="list-unstyled mt-1 mb-0">${Array.from(this.files).map(f => `<li class="text-truncate" style="font-size: 11px;">• ${f.name}</li>`).join('')}</ul>`;
        } else {
          info.classList.add('d-none');
          info.innerHTML = '';
        }
      });
    }
  </script>

  <style>
    .select-files-box:hover .upload-icon {
      color: #7c3aed !important;
    }
    .select-files-box:hover {
      border-color: rgba(124, 58, 237, 0.4) !important;
      background-color: rgba(15, 23, 42, 0.4) !important;
    }
  </style>

</body>
</html>
