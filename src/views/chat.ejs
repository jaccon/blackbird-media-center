<!DOCTYPE html>
<html lang="<%= currentLang %>">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI Intelligence Hub - Black Bird Media Center</title>
  <style>
    .ai-hub-container {
      display: flex;
      gap: 1.5rem;
      height: 78vh;
      margin-top: 1rem;
    }

    /* Left Sidebar: Threads */
    .ai-threads-sidebar {
      width: 260px;
      flex-shrink: 0;
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 18px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    /* Right Sidebar: Agents list */
    .ai-agents-sidebar {
      width: 280px;
      flex-shrink: 0;
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 18px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    }

    /* Center: Conversation */
    .ai-chat-window {
      flex-grow: 1;
      background: rgba(15, 23, 42, 0.55);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 20px;
      display: flex;
      flex-direction: column;
      overflow: hidden;
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.35);
    }

    /* Thread Item list */
    .thread-list-container {
      flex-grow: 1;
      overflow-y: auto;
      padding: 0.75rem;
    }

    .thread-item {
      padding: 0.85rem 1rem;
      border-radius: 12px;
      color: #94a3b8;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.2s ease;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.4rem;
      border: 1px solid transparent;
    }

    .thread-item:hover {
      background: rgba(255, 255, 255, 0.04);
      color: #ffffff;
    }

    .thread-item.active {
      background: rgba(124, 58, 237, 0.15);
      color: #ffffff;
      border-color: rgba(124, 58, 237, 0.25);
    }

    .thread-title {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      flex-grow: 1;
      margin-right: 0.5rem;
    }

    .btn-delete-thread {
      opacity: 0;
      color: #ef4444;
      background: none;
      border: none;
      padding: 0.1rem 0.3rem;
      cursor: pointer;
      transition: opacity 0.2s ease;
    }

    .thread-item:hover .btn-delete-thread {
      opacity: 1;
    }

    /* Agent Item list */
    .agent-list-container {
      flex-grow: 1;
      overflow-y: auto;
      padding: 0.75rem;
    }

    .agent-item-card {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.04);
      border-radius: 12px;
      padding: 0.9rem;
      margin-bottom: 0.6rem;
      transition: all 0.2s ease;
    }

    .agent-item-card:hover {
      border-color: rgba(124, 58, 237, 0.2);
      background: rgba(255, 255, 255, 0.03);
    }

    .agent-header-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.25rem;
    }

    .agent-item-name {
      font-size: 13px;
      font-weight: 600;
      color: #ffffff;
    }

    .agent-item-profile {
      font-size: 10.5px;
      color: #a78bfa;
      font-weight: 500;
    }

    .agent-item-skills {
      font-size: 11.5px;
      color: #94a3b8;
      line-height: 1.4;
      margin-bottom: 0.4rem;
    }

    /* Active Chat styles */
    .chat-messages {
      flex-grow: 1;
      overflow-y: auto;
      min-height: 0; /* Flexbox scroll fix */
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .message-bubble {
      max-width: 80%;
      padding: 1rem 1.25rem;
      border-radius: 16px;
      font-size: 14.5px;
      line-height: 1.55;
      animation: fadeInBubble 0.25s ease-out;
    }

    .message-user {
      align-self: flex-end;
      background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
      color: #ffffff;
      border-bottom-right-radius: 4px;
      box-shadow: 0 4px 15px rgba(124, 58, 237, 0.2);
    }

    .message-ai {
      align-self: flex-start;
      background-color: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.04);
      color: #f1f5f9;
      border-bottom-left-radius: 4px;
    }

    .chat-header-actions {
      background-color: rgba(255, 255, 255, 0.02);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      padding: 0.8rem 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0; /* Never compressed layout fix */
    }

    .chat-input-area {
      background-color: rgba(255, 255, 255, 0.01);
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding: 1rem 1.5rem;
      flex-shrink: 0; /* Never compressed layout fix */
    }

    .input-wrapper {
      position: relative;
      display: flex;
      gap: 0.85rem;
      align-items: center;
    }

    .chat-input {
      flex-grow: 1;
      background-color: rgba(15, 23, 42, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 0.85rem 1.25rem;
      color: #ffffff;
      font-size: 14.5px;
      outline: none;
      transition: all 0.2s ease;
      height: 50px;
    }

    .chat-input:focus {
      border-color: rgba(124, 58, 237, 0.4);
      box-shadow: 0 0 10px rgba(124, 58, 237, 0.15);
    }

    .btn-send {
      background: linear-gradient(135deg, #7c3aed 0%, #4f46e5 100%);
      border: none;
      color: #ffffff;
      border-radius: 12px;
      width: 50px;
      height: 50px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s ease;
      box-shadow: 0 4px 10px rgba(124, 58, 237, 0.2);
    }

    .btn-send:hover {
      transform: scale(1.03);
      box-shadow: 0 6px 15px rgba(124, 58, 237, 0.35);
    }

    .typing-dot {
      width: 6px;
      height: 6px;
      background-color: rgba(255, 255, 255, 0.5);
      border-radius: 50%;
      animation: typingBounce 1.4s infinite ease-in-out both;
    }

    .typing-dot:nth-child(1) { animation-delay: -0.32s; }
    .typing-dot:nth-child(2) { animation-delay: -0.16s; }

    @keyframes typingBounce {
      0%, 80%, 100% { transform: scale(0); }
      40% { transform: scale(1); }
    }

    @keyframes fadeInBubble {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload Files</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Select files to upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Media files will be saved to root folder</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
        </div>
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Upload</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Criar Pasta (Necessário por estar no header.ejs) -->
  <div class="modal fade animate" id="createFolderModal" tabindex="-1" aria-labelledby="createFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="createFolderModalLabel"><%= t('create_folder') %></h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/create-dir" method="POST" class="m-0">
          <div class="modal-body p-4">
            <input type="hidden" name="path" id="createFolderPathInput" value="">
            <div class="mb-3">
              <label for="dirNameInput" class="form-label text-uppercase text-secondary fw-semibold small tracking-wider mb-2"><%= t('folder_name') %></label>
              <input type="text" id="dirNameInput" name="dirName" placeholder="Ex: Pasta Nova" required class="form-control input-premium">
            </div>
          </div>
          <div class="modal-footer modal-footer-premium border-0">
            <button type="button" class="btn btn-premium-secondary" data-bs-dismiss="modal"><%= t('cancel') %></button>
            <button type="submit" class="btn btn-premium-primary border-0"><%= t('create') %></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- MODAL: CRIAR NOVO AGENTE DE AI -->
  <div class="modal fade animate" id="createAgentModal" tabindex="-1" aria-labelledby="createAgentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="createAgentModalLabel">Create New AI Agent</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="createAgentForm" class="m-0">
          <div class="modal-body p-4">
            
            <div class="mb-3">
              <label for="newAgentName" class="form-label text-secondary fw-semibold small mb-2">Agent Name</label>
              <input type="text" id="newAgentName" placeholder="e.g. Winston, Sally" required class="form-control input-premium">
            </div>

            <div class="mb-3">
              <label for="newAgentProfile" class="form-label text-secondary fw-semibold small mb-2">Profile / Responsibility</label>
              <input type="text" id="newAgentProfile" placeholder="e.g. UX Specialist, System Architect" required class="form-control input-premium">
            </div>

            <div class="mb-3">
              <label for="newAgentSkills" class="form-label text-secondary fw-semibold small mb-2">Skills & Instructions</label>
              <textarea id="newAgentSkills" rows="3" placeholder="Define the agent skills and instructions..." required class="form-control input-premium"></textarea>
            </div>

            <div class="row g-3 mb-3">
              <div class="col-md-7">
                <label for="newAgentModel" class="form-label text-secondary fw-semibold small mb-2">Hugging Face Model</label>
                <input type="text" id="newAgentModel" value="meta-llama/Llama-3.1-8B-Instruct" class="form-control input-premium">
              </div>
              <div class="col-md-5">
                <label for="newAgentTemp" class="form-label text-secondary fw-semibold small mb-2">Temperature</label>
                <input type="number" id="newAgentTemp" value="0.7" min="0" max="1.5" step="0.1" class="form-control input-premium">
              </div>
            </div>

            <div class="form-check form-switch mt-3">
              <input class="form-check-input cursor-pointer" type="checkbox" id="newAgentPublic" value="true" checked>
              <label class="form-check-label text-secondary small" for="newAgentPublic">Agent is Public (Available to all users)</label>
            </div>

            <div class="form-check form-switch mt-2">
              <input class="form-check-input cursor-pointer" type="checkbox" id="newAgentProactive" value="true">
              <label class="form-check-label text-secondary small" for="newAgentProactive">Proactive Agent (Sends proactive alerts & messages)</label>
            </div>

          </div>
          <div class="modal-footer modal-footer-premium border-0">
            <button type="button" class="btn btn-premium-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-premium-primary border-0">Save Agent</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- CONTAINER HUB PRINCIPAL -->
  <div class="container-xl py-4 px-3">
    
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h2 class="fs-4 fw-bold text-white font-outfit m-0">Artificial Intelligence Hub</h2>
        <p class="text-secondary small m-0 mt-1">Manage separate conversation threads, create and consult agents with dedicated responsibilities.</p>
      </div>
    </div>

    <div class="ai-hub-container">
      
      <!-- Coluna 1: Conversas abertas -->
      <aside class="ai-threads-sidebar">
        <div class="p-3 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
          <span class="text-white fw-bold font-outfit small">Active Chats</span>
          <button class="btn btn-premium-primary btn-sm py-1 px-2.5 font-outfit" onclick="createNewThread()" style="font-size: 11.5px;">
            <i class="bi bi-plus-lg me-1"></i>New
          </button>
        </div>
        <div class="thread-list-container" id="threadList">
          <% Object.keys(chatHistory.sessions).forEach(key => { 
             const sess = chatHistory.sessions[key]; %>
            <div class="thread-item <%= chatHistory.currentSessionId === key ? 'active' : '' %>" 
                 id="thread-item-<%= key %>" 
                 onclick="switchThread('<%= key %>')">
              <span class="thread-title" id="thread-title-<%= key %>"><%= sess.title %></span>
              <button class="btn-delete-thread" onclick="deleteThread(event, '<%= key %>')">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          <% }) %>
        </div>
      </aside>

      <!-- Coluna 2: Chat Activo -->
      <main class="ai-chat-window">
        <!-- Top bar: Selection of Agents -->
        <div class="chat-header-actions">
          <div class="d-flex align-items-center gap-2">
            <span class="text-secondary small">Chatting with:</span>
            <select id="chatAgentSelect" class="form-select form-control input-premium py-1 pe-5" style="background-color: rgba(15, 23, 42, 0.45); font-size: 12.5px; width: 220px;">
              <% agentsList.forEach(agent => { %>
                <option value="<%= agent.id %>"><%= agent.name %> (<%= agent.profile %>)</option>
              <% }) %>
            </select>
          </div>
          
          <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary" style="font-size: 11px;">
            Llama-3.1-8B via Hugging Face
          </span>
        </div>

        <!-- Mensagens do Chat -->
        <div class="chat-messages" id="chatMessagesBox">
          <!-- Populated dynamically via JS -->
        </div>

        <!-- Input Area -->
        <div class="chat-input-area">
          <form id="chatForm" class="input-wrapper m-0">
            <input type="text" id="chatInput" placeholder="Send your message to the agent..." required class="chat-input">
            <button type="submit" class="btn-send">
              <i class="bi bi-send-fill fs-5"></i>
            </button>
          </form>
        </div>
      </main>

      <!-- Coluna 3: Agentes Criados -->
      <aside class="ai-agents-sidebar">
        <div class="p-3 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
          <span class="text-white fw-bold font-outfit small">Created Agents</span>
          <button class="btn btn-premium-secondary btn-sm py-1 px-2" data-bs-toggle="modal" data-bs-target="#createAgentModal" style="font-size: 11.5px;">
            <i class="bi bi-person-plus me-1"></i>New Agent
          </button>
        </div>
        <div class="agent-list-container" id="agentsContainer">
          <% agentsList.forEach(agent => { %>
            <div class="agent-item-card">
              <div class="agent-header-meta">
                <span class="agent-item-name"><%= agent.name %></span>
                <span class="agent-item-profile"><%= agent.profile %></span>
              </div>
              <p class="agent-item-skills mb-1.5 text-secondary"><%= agent.skills %></p>
              <div class="d-flex justify-content-between align-items-center">
                <span class="text-secondary" style="font-size: 9.5px; font-family: monospace;"><%= agent.model.split('/').pop() %></span>
                <div class="d-flex gap-1">
                  <% if (agent.isProactive) { %>
                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-20" style="font-size: 8.5px;">Proactive</span>
                  <% } %>
                  <% if (agent.isPublic) { %>
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20" style="font-size: 8.5px;">Public</span>
                  <% } else { %>
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-20" style="font-size: 8.5px;">Private</span>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </aside>

    </div>

  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>

  <script>
    let activeSessionId = '<%= chatHistory.currentSessionId || "default" %>';
    
    // Configurar sessões a partir do servidor em runtime
    const sessions = <%- JSON.stringify(chatHistory.sessions) %>;

    document.addEventListener('DOMContentLoaded', () => {
      // Carregar as mensagens da conversa ativa inicialmente
      renderActiveSessionMessages();

      // Form para envio de chats
      const chatForm = document.getElementById('chatForm');
      if (chatForm) {
        chatForm.addEventListener('submit', (e) => {
          e.preventDefault();
          handleSendMessage();
        });
      }

      // Form para criação de novos agentes
      const createAgentForm = document.getElementById('createAgentForm');
      if (createAgentForm) {
        createAgentForm.addEventListener('submit', (e) => {
          e.preventDefault();
          handleCreateAgentSubmit();
        });
      }
    });

    function toggleAgentModal() {
      const el = document.getElementById('createAgentModal');
      let instance = bootstrap.Modal.getInstance(el);
      if (!instance) {
        instance = new bootstrap.Modal(el);
      }
      if (el.classList.contains('show')) {
        instance.hide();
      } else {
        instance.show();
      }
    }

    function renderActiveSessionMessages() {
      const container = document.getElementById('chatMessagesBox');
      container.innerHTML = '';
      
      const currentSession = sessions[activeSessionId];
      if (!currentSession || !currentSession.messages || currentSession.messages.length === 0) {
        container.innerHTML = `
          <div class="text-center py-5 my-auto text-secondary opacity-50">
            <i class="bi bi-robot fs-1 mb-2 d-block"></i>
            <span>No messages in this conversation yet. Send a prompt to start chatting!</span>
          </div>
        `;
        return;
      }

      currentSession.messages.forEach(msg => {
        const bubble = document.createElement('div');
        bubble.className = 'message-bubble ' + (msg.role === 'user' ? 'message-user' : 'message-ai');
        
        if (msg.role === 'user') {
          bubble.innerText = msg.content;
        } else {
          bubble.innerHTML = formatAIResponse(msg.content);
        }
        
        container.appendChild(bubble);
      });
      
      scrollChatToBottom();
    }

    function switchThread(sessionId) {
      if (activeSessionId === sessionId) return;
      
      // Remover active da anterior
      const oldActive = document.querySelector('.thread-item.active');
      if (oldActive) oldActive.classList.remove('active');
      
      // Add active na nova
      const newActive = document.getElementById(`thread-item-${sessionId}`);
      if (newActive) newActive.classList.add('active');
      
      activeSessionId = sessionId;
      renderActiveSessionMessages();
    }

    function createNewThread() {
      Swal.fire({
        title: 'New Conversation',
        input: 'text',
        inputPlaceholder: 'Conversation subject...',
        showCancelButton: true,
        confirmButtonColor: '#7c3aed',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Create',
        cancelButtonText: 'Cancel',
        background: '#0f172a',
        color: '#ffffff'
      }).then((result) => {
        if (result.isConfirmed && result.value) {
          const title = result.value.trim() || 'New Conversation';
          
          fetch('/api/chat/session/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              // Adicionar localmente
              sessions[data.sessionId] = {
                id: data.sessionId,
                title: data.title,
                messages: []
              };
              
              // Renderizar item na lista
              const threadList = document.getElementById('threadList');
              const threadDiv = document.createElement('div');
              threadDiv.className = 'thread-item';
              threadDiv.id = `thread-item-${data.sessionId}`;
              threadDiv.setAttribute('onclick', `switchThread('${data.sessionId}')`);
              threadDiv.innerHTML = `
                <span class="thread-title" id="thread-title-${data.sessionId}">${data.title}</span>
                <button class="btn-delete-thread" onclick="deleteThread(event, '${data.sessionId}')">
                  <i class="bi bi-trash"></i>
                </button>
              `;
              threadList.insertBefore(threadDiv, threadList.firstChild);
              
              // Mudar
              switchThread(data.sessionId);
            }
          });
        }
      });
    }

    function deleteThread(event, sessionId) {
      event.stopPropagation();
      Swal.fire({
        title: 'Delete Conversation?',
        text: "This thread's chat history will be permanently deleted!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#64748b',
        confirmButtonText: 'Delete',
        cancelButtonText: 'Cancel',
        background: '#0f172a',
        color: '#ffffff'
      }).then((result) => {
        if (result.isConfirmed) {
          fetch('/api/chat/session/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ sessionId })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              delete sessions[sessionId];
              document.getElementById(`thread-item-${sessionId}`).remove();
              
              // Mudar para a nova ativa resolvida pelo servidor
              if (activeSessionId === sessionId) {
                activeSessionId = data.currentSessionId;
                // Garantir que exista localmente
                if (!sessions[activeSessionId]) {
                  sessions[activeSessionId] = {
                    id: activeSessionId,
                    title: 'Conversa Geral',
                    messages: []
                  };
                }
                
                // Forçar marcação na lista
                const listItems = document.querySelectorAll('.thread-item');
                listItems.forEach(item => {
                  if (item.id === `thread-item-${activeSessionId}`) {
                    item.classList.add('active');
                  } else {
                    item.classList.remove('active');
                  }
                });
                
                renderActiveSessionMessages();
              }
            }
          });
        }
      });
    }

    function handleSendMessage() {
      const input = document.getElementById('chatInput');
      const text = input.value.trim();
      const agentId = document.getElementById('chatAgentSelect').value;
      
      if (!text) return;
      
      // Mostrar mensagem do usuário localmente
      const container = document.getElementById('chatMessagesBox');
      
      // Limpar placeholder inicial
      if (!sessions[activeSessionId] || sessions[activeSessionId].messages.length === 0) {
        container.innerHTML = '';
      }
      
      const userBubble = document.createElement('div');
      userBubble.className = 'message-bubble message-user';
      userBubble.innerText = text;
      container.appendChild(userBubble);
      scrollChatToBottom();
      
      input.value = '';

      // Adicionar no histórico local provisoriamente
      if (!sessions[activeSessionId]) {
        sessions[activeSessionId] = { id: activeSessionId, title: 'Conversa', messages: [] };
      }
      sessions[activeSessionId].messages.push({ role: 'user', content: text });

      // Adicionar Typing Indicator
      const indicator = document.createElement('div');
      indicator.className = 'message-bubble message-ai';
      indicator.id = 'aiHubTypingIndicator';
      indicator.innerHTML = `
        <div class="d-flex gap-1.5 align-items-center py-1">
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
          <div class="typing-dot"></div>
        </div>
      `;
      container.appendChild(indicator);
      scrollChatToBottom();

      // Chamar API
      fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: text,
          sessionId: activeSessionId,
          agentId: agentId
        })
      })
      .then(res => res.json())
      .then(data => {
        document.getElementById('aiHubTypingIndicator').remove();
        if (data.success) {
          // Salvar localmente
          sessions[data.sessionId].messages.push({ role: 'assistant', content: data.response });
          
          // Se mudou o nome da thread na primeira mensagem
          if (data.sessionTitle) {
            sessions[data.sessionId].title = data.sessionTitle;
            const titleEl = document.getElementById(`thread-title-${data.sessionId}`);
            if (titleEl) titleEl.innerText = data.sessionTitle;
          }

          // Adicionar mensagem do bot
          const aiBubble = document.createElement('div');
          aiBubble.className = 'message-bubble message-ai';
          aiBubble.innerHTML = formatAIResponse(data.response);
          container.appendChild(aiBubble);
          scrollChatToBottom();
        }
      })
      .catch(err => {
        console.error(err);
        const ind = document.getElementById('aiHubTypingIndicator');
        if (ind) ind.remove();
      });
    }

    function handleCreateAgentSubmit() {
      const name = document.getElementById('newAgentName').value.trim();
      const profile = document.getElementById('newAgentProfile').value.trim();
      const skills = document.getElementById('newAgentSkills').value.trim();
      const model = document.getElementById('newAgentModel').value.trim();
      const temperature = document.getElementById('newAgentTemp').value.trim();
      const isPublic = document.getElementById('newAgentPublic').checked;
      const isProactive = document.getElementById('newAgentProactive').checked;

      fetch('/api/agents/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, profile, skills, model, temperature, isPublic, isProactive })
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          toggleAgentModal();
          
          // Adicionar ao dropdown
          const select = document.getElementById('chatAgentSelect');
          const option = document.createElement('option');
          option.value = data.agent.id;
          option.innerText = `${data.agent.name} (${data.agent.profile})`;
          select.appendChild(option);

          // Adicionar na lista lateral
          const container = document.getElementById('agentsContainer');
          const card = document.createElement('div');
          card.className = 'agent-item-card';
          card.innerHTML = `
            <div class="agent-header-meta">
              <span class="agent-item-name">${data.agent.name}</span>
              <span class="agent-item-profile">${data.agent.profile}</span>
            </div>
            <p class="agent-item-skills mb-1.5 text-secondary">${data.agent.skills}</p>
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-secondary" style="font-size: 9.5px; font-family: monospace;">${data.agent.model.split('/').pop()}</span>
              <div class="d-flex gap-1">
                ${data.agent.isProactive ? '<span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-20" style="font-size: 8.5px;">Proactive</span>' : ''}
                <span class="badge ${data.agent.isPublic ? 'bg-success bg-opacity-10 text-success' : 'bg-warning bg-opacity-10 text-warning'} border" style="font-size: 8.5px;">
                  ${data.agent.isPublic ? 'Public' : 'Private'}
                </span>
              </div>
            </div>
          `;
          container.appendChild(card);

          Swal.fire({
            icon: 'success',
            title: 'Agent Created',
            text: `Agent ${data.agent.name} was successfully configured and is ready to chat!`,
            background: '#0f172a',
            color: '#ffffff'
          });

          // Limpar form
          document.getElementById('createAgentForm').reset();
        }
      });
    }

    function scrollChatToBottom() {
      const box = document.getElementById('chatMessagesBox');
      box.scrollTop = box.scrollHeight;
    }

    function formatAIResponse(text) {
      let formatted = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

      formatted = formatted.replace(/```json\s*([\s\S]+?)\s*```/g, ''); // Hide raw JSON commands
      formatted = formatted.replace(/```([\s\S]+?)```/g, '<pre><code>$1</code></pre>');
      formatted = formatted.replace(/\*\*([\s\S]+?)\*\*/g, '<strong>$1</strong>');
      formatted = formatted.replace(/\n/g, '<br>');
      return formatted;
    }
  </script>
</body>

</html>
