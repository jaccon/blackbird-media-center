<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Editar Comentário - Black Bird Media Center</title>
</head>
<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
        </div>
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Criar Pasta (Necessário por estar no header.ejs) -->
  <div class="modal fade animate" id="createFolderModal" tabindex="-1" aria-labelledby="createFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="createFolderModalLabel"><%= t('create_folder') %></h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleCreateFolderModal()" aria-label="Close"></button>
        </div>
        <form action="/create-dir" method="POST" class="m-0">
          <div class="modal-body p-4">
            <input type="hidden" name="path" id="createFolderPathInput" value="">
            <div class="mb-3">
              <label for="dirNameInput" class="form-label text-uppercase text-secondary fw-semibold small tracking-wider mb-2"><%= t('folder_name') %></label>
              <input type="text" id="dirNameInput" name="dirName" placeholder="Ex: Pasta Nova" required class="form-control input-premium">
            </div>
          </div>
          <div class="modal-footer modal-footer-premium border-0">
            <button type="button" class="btn btn-premium-secondary" onclick="toggleCreateFolderModal()"><%= t('cancel') %></button>
            <button type="submit" class="btn btn-premium-primary border-0"><%= t('create') %></button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="container-xl py-4 px-3">
    
    <!-- Título & Breadcrumb -->
    <div class="mb-4">
      <div class="d-flex align-items-center gap-2 mb-2">
        <a href="/tasks/edit/<%= card.id %>" class="btn btn-premium-secondary btn-sm py-1 px-2 d-inline-flex align-items-center gap-1.5" style="font-size: 11px; border-radius: 8px;">
          <i class="bi bi-arrow-left"></i>
          <span>Voltar à Tarefa</span>
        </a>
        <span class="text-secondary">/</span>
        <span class="text-secondary small font-outfit text-truncate" style="max-width: 150px;"><%= card.title %></span>
        <span class="text-secondary">/</span>
        <span class="text-fuchsia-500 fw-bold font-outfit text-uppercase" style="font-size: 11px; letter-spacing: 0.5px;">Comentário</span>
      </div>
      <h2 class="fs-4 fw-bold text-white font-outfit m-0">Editar Comentário</h2>
      <p class="text-secondary small m-0 mt-1">Edite o texto e gerencie as mídias (vídeos, imagens) deste comentário.</p>
    </div>

    <!-- Form Container -->
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        
        <div class="card border border-secondary border-opacity-10 shadow-lg" style="background-color: rgba(15, 23, 42, 0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-radius: 16px;">
          <div class="card-header border-bottom border-secondary border-opacity-10 bg-transparent py-3 px-4">
            <h5 class="card-title font-outfit fw-semibold text-white m-0 d-flex align-items-center gap-2">
              <i class="bi bi-chat-left-text text-gradient"></i>
              ID do Comentário: <span class="text-info"><%= comment.id %></span>
            </h5>
          </div>

          <div class="card-body p-4">
            
            <% if (typeof successMsg !== 'undefined' && successMsg) { %>
              <div class="alert alert-success py-2 px-3 small border-0 mb-4 animate-fade-in" style="background-color: rgba(25, 135, 84, 0.15); color: #75b798; border-radius: 8px;">
                <i class="bi bi-check-circle-fill me-2"></i> <%= successMsg %>
              </div>
            <% } %>

            <form action="/tasks/comment/<%= comment.id %>" method="POST" id="commentEditForm">
              <input type="hidden" name="attachmentsJson" id="attachmentsJson">
              
              <!-- Texto do Comentário -->
              <div class="mb-4">
                <label for="text" class="form-label text-white fw-semibold mb-1" style="font-size: 14px;">Texto do Comentário</label>
                <textarea id="text" name="text" rows="5" required placeholder="Texto do comentário..." class="form-control input-premium"><%= comment.text %></textarea>
              </div>

              <!-- Mídias / Anexos Atuais -->
              <div class="mb-4">
                <label class="form-label text-white fw-semibold mb-1" style="font-size: 14px;">Mídias Anexadas (Imagens e Vídeos)</label>
                <p class="text-secondary small mb-2.5" style="font-size: 11px;">Clique na mídia para visualizar em tela cheia ou no ícone vermelho para removê-la.</p>
                
                <div id="attachmentsContainer" class="d-flex flex-wrap gap-3 p-3 rounded border border-secondary border-opacity-10" style="background-color: rgba(15, 23, 42, 0.25);">
                  <!-- Gerado dinamicamente -->
                </div>
              </div>

              <!-- Anexar Novas Mídias -->
              <div class="mb-4">
                <label class="form-label text-white fw-semibold mb-1" style="font-size: 14px;">Anexar Novas Mídias</label>
                <div class="d-flex align-items-center gap-2">
                  <button type="button" class="btn btn-premium-secondary d-flex align-items-center gap-2" onclick="triggerCommentAttachment()">
                    <i class="bi bi-paperclip fs-5 text-secondary"></i>
                    <span>Selecionar Imagens / Vídeos</span>
                  </button>
                  <input type="file" id="commentAttachmentInput" accept="image/*,video/*" multiple class="d-none" onchange="handleCommentAttachmentSelect(event)">
                </div>
                <div id="commentAttachmentsPreview" class="d-flex flex-wrap gap-1.5 small mt-2.5 d-none"></div>
              </div>

              <!-- Botões de Ação -->
              <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top border-secondary border-opacity-10">
                <a href="/tasks/edit/<%= card.id %>" class="btn btn-premium-secondary px-4"><%= t('cancel') %></a>
                <button type="submit" class="btn btn-premium-primary border-0 px-4">Salvar Alterações</button>
              </div>

            </form>

          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    let currentAttachments = <%- JSON.stringify(comment.attachments || []) %>;
    let selectedFiles = [];

    function escapeHtml(text) {
      if (!text) return '';
      return text
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function renderAttachments() {
      const container = document.getElementById('attachmentsContainer');
      container.innerHTML = '';
      
      if (currentAttachments.length === 0) {
        container.innerHTML = `<span class="text-secondary small font-outfit py-2">Nenhuma mídia anexada a este comentário.</span>`;
        return;
      }
      
      currentAttachments.forEach((att, index) => {
        const item = document.createElement('div');
        item.className = 'position-relative';
        item.style.width = '100px';
        item.style.height = '100px';
        
        let mediaHtml = '';
        if (att.type === 'image') {
          mediaHtml = `<img src="${att.url}" class="rounded border border-secondary border-opacity-20 hover-opacity-75 transition-all-200" style="width: 100%; height: 100%; object-fit: cover; cursor: pointer;" onclick="viewFullScreen('${att.url}', 'image')">`;
        } else {
          mediaHtml = `
            <div class="position-relative w-100 h-100 rounded border border-secondary border-opacity-20 bg-dark overflow-hidden cursor-pointer" onclick="viewFullScreen('${att.url}', 'video')">
              <video src="${att.url}" style="width: 100%; height: 100%; object-fit: cover;"></video>
              <div class="position-absolute top-50 start-50 translate-middle bg-dark bg-opacity-70 rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                <i class="bi bi-play-fill text-white fs-6" style="margin-left: 2px;"></i>
              </div>
            </div>
          `;
        }
        
        item.innerHTML = `
          ${mediaHtml}
          <button type="button" class="btn btn-danger btn-sm rounded-circle position-absolute" style="top: -6px; right: -6px; width: 22px; height: 22px; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 10px;" onclick="removeAttachment(${index})">
            <i class="bi bi-trash-fill"></i>
          </button>
        `;
        
        container.appendChild(item);
      });
    }

    function removeAttachment(index) {
      currentAttachments.splice(index, 1);
      renderAttachments();
    }

    function triggerCommentAttachment() {
      document.getElementById('commentAttachmentInput').click();
    }

    function handleCommentAttachmentSelect(e) {
      const files = e.target.files;
      if (!files || files.length === 0) return;
      
      const previewContainer = document.getElementById('commentAttachmentsPreview');
      previewContainer.classList.remove('d-none');
      
      Array.from(files).forEach(file => {
        selectedFiles.push(file);
      });
      
      renderNewPreviews();
      e.target.value = '';
    }

    function removeSelectedFile(index) {
      selectedFiles.splice(index, 1);
      renderNewPreviews();
    }

    function renderNewPreviews() {
      const previewContainer = document.getElementById('commentAttachmentsPreview');
      previewContainer.innerHTML = '';
      
      if (selectedFiles.length === 0) {
        previewContainer.classList.add('d-none');
        return;
      }
      
      previewContainer.classList.remove('d-none');
      selectedFiles.forEach((file, index) => {
        const pill = document.createElement('span');
        pill.className = 'badge bg-secondary bg-opacity-25 border border-secondary border-opacity-25 text-white d-inline-flex align-items-center gap-1.5 py-1 px-2';
        pill.style.fontSize = '10px';
        pill.style.borderRadius = '6px';
        
        const iconClass = file.type.startsWith('image/') ? 'bi-image' : 'bi-film';
        pill.innerHTML = `
          <i class="bi ${iconClass}"></i>
          <span class="text-truncate" style="max-width: 80px;">${escapeHtml(file.name)}</span>
          <i class="bi bi-x-circle-fill text-danger cursor-pointer" onclick="removeSelectedFile(${index})"></i>
        `;
        previewContainer.appendChild(pill);
      });
    }

    function uploadNewFiles() {
      if (selectedFiles.length === 0) {
        return Promise.resolve([]);
      }
      
      const CHUNK_SIZE = 5 * 1024 * 1024;
      
      if (window.Swal) {
        Swal.fire({
          title: 'Enviando novos arquivos...',
          text: 'Fazendo upload das mídias...',
          allowOutsideClick: false,
          didOpen: () => {
            Swal.showLoading();
          }
        });
      }

      let uploadedList = [];
      let chain = Promise.resolve();
      
      selectedFiles.forEach(file => {
        chain = chain.then(() => {
          return new Promise((resolve, reject) => {
            const totalChunks = Math.ceil(file.size / CHUNK_SIZE);
            let chunkIndex = 0;
            let finalUrl = '';
            
            function uploadNext() {
              if (chunkIndex >= totalChunks) {
                uploadedList.push({
                  type: file.type.startsWith('image/') ? 'image' : 'video',
                  url: finalUrl || ('/shared/' + encodeURIComponent(file.name)),
                  name: file.name
                });
                resolve();
                return;
              }
              
              const start = chunkIndex * CHUNK_SIZE;
              const end = Math.min(start + CHUNK_SIZE, file.size);
              const chunk = file.slice(start, end);
              
              const url = `/upload-chunk?chunkIndex=${chunkIndex}&totalChunks=${totalChunks}&fileName=${encodeURIComponent(file.name)}&currentPath=${encodeURIComponent('tasks/<%= card.id %>/<%= comment.id %>')}`;
              
              fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/octet-stream' },
                body: chunk
              })
              .then(res => res.json())
              .then(result => {
                if (result.success) {
                  if (result.url) {
                    finalUrl = result.url;
                  }
                  chunkIndex++;
                  uploadNext();
                } else {
                  reject(new Error(result.error || 'Erro ao enviar fragmento do arquivo'));
                }
              })
              .catch(err => reject(err));
            }
            
            uploadNext();
          });
        });
      });
      
      return chain.then(() => {
        if (window.Swal) Swal.close();
        return uploadedList;
      });
    }

    function viewFullScreen(url, type) {
      const overlay = document.createElement('div');
      overlay.style.position = 'fixed';
      overlay.style.top = '0';
      overlay.style.left = '0';
      overlay.style.width = '100vw';
      overlay.style.height = '100vh';
      overlay.style.backgroundColor = '#000000';
      overlay.style.zIndex = '9999';
      overlay.style.display = 'flex';
      overlay.style.flexDirection = 'column';
      overlay.style.justifyContent = 'center';
      overlay.style.alignItems = 'center';
      overlay.style.animation = 'fadeIn 0.3s ease';

      const closeBtn = document.createElement('button');
      closeBtn.innerHTML = '<i class="bi bi-x-lg fs-4"></i>';
      closeBtn.style.position = 'absolute';
      closeBtn.style.top = '1.5rem';
      closeBtn.style.right = '1.5rem';
      closeBtn.style.background = 'rgba(255, 255, 255, 0.1)';
      closeBtn.style.border = 'none';
      closeBtn.style.color = '#ffffff';
      closeBtn.style.width = '44px';
      closeBtn.style.height = '44px';
      closeBtn.style.borderRadius = '50%';
      closeBtn.style.cursor = 'pointer';
      closeBtn.onclick = () => {
        overlay.style.animation = 'fadeOut 0.3s ease';
        setTimeout(() => overlay.remove(), 250);
      };
      overlay.appendChild(closeBtn);

      let mediaEl;
      if (type === 'image') {
        mediaEl = document.createElement('img');
        mediaEl.src = url;
        mediaEl.style.maxWidth = '90%';
        mediaEl.style.maxHeight = '80vh';
        mediaEl.style.objectFit = 'contain';
      } else {
        mediaEl = document.createElement('video');
        mediaEl.src = url;
        mediaEl.controls = true;
        mediaEl.autoplay = true;
        mediaEl.style.maxWidth = '90%';
        mediaEl.style.maxHeight = '80vh';
      }
      mediaEl.style.borderRadius = '8px';
      overlay.appendChild(mediaEl);

      const text = document.getElementById('text').value.trim();
      if (text) {
        const textOverlay = document.createElement('div');
        textOverlay.style.position = 'absolute';
        textOverlay.style.bottom = '0';
        textOverlay.style.width = '100%';
        textOverlay.style.background = 'linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 70%, rgba(0,0,0,0) 100%)';
        textOverlay.style.padding = '2rem 1.5rem';
        textOverlay.style.textAlign = 'center';
        
        const textP = document.createElement('p');
        textP.className = 'font-outfit text-white m-0';
        textP.style.fontSize = '15px';
        textP.style.lineHeight = '1.5';
        textP.textContent = text;
        textOverlay.appendChild(textP);
        
        overlay.appendChild(textOverlay);
      }

      if (!document.getElementById('fullScreenAnimationStyles')) {
        const style = document.createElement('style');
        style.id = 'fullScreenAnimationStyles';
        style.innerHTML = `
          @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
          @keyframes fadeOut { from { opacity: 1; } to { opacity: 0; } }
        `;
        document.head.appendChild(style);
      }

      document.body.appendChild(overlay);
    }

    // Intercept form submit to upload files first and encode attachments array
    document.getElementById('commentEditForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const form = this;
      
      uploadNewFiles()
        .then(newAttachments => {
          // Merge old and new attachments
          const finalAttachments = currentAttachments.concat(newAttachments);
          document.getElementById('attachmentsJson').value = JSON.stringify(finalAttachments);
          
          // Submit form natively
          form.submit();
        })
        .catch(err => {
          Swal.fire({
            icon: 'error',
            title: 'Erro no Upload',
            text: err.message
          });
        });
    });

    // Initial render
    renderAttachments();
  </script>

</body>
</html>
