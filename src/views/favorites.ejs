<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Favoritos - Black Bird Media Center</title>
</head>
<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) (Bootstrap 5) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <!-- Modal Header -->
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <!-- Modal Body -->
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
          <div id="selectedFilesInfo" class="small text-secondary mt-3 p-3 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10 d-none" style="max-height: 110px; overflow-y: auto;"></div>
        </div>
        <!-- Modal Footer -->
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xl py-4 px-3">
    
    <!-- Título -->
    <div class="mb-4">
      <h2 class="fs-4 fw-bold text-white font-outfit m-0"><%= t('favorites') %></h2>
      <p class="text-secondary small m-0 mt-1">Lista de arquivos marcados com estrela para acesso rápido</p>
    </div>

    <!-- Lista de Favoritos -->
    <% if (favorites.length === 0) { %>
      <div class="text-center py-5 rounded-3 border border-secondary border-opacity-10" style="background-color: rgba(15, 23, 42, 0.25);">
        <i class="bi bi-star-half text-secondary block mb-3" style="font-size: 3rem;"></i>
        <h3 class="fs-5 fw-bold text-white font-outfit">Nenhum favorito salvo</h3>
        <p class="text-secondary small mt-1 max-w-sm mx-auto mb-3">Favorite arquivos na Home clicando na estrela para que eles apareçam aqui.</p>
        <a href="/explorer" class="btn btn-premium-primary border-0 text-decoration-none">
          Explorar Arquivos
        </a>
      </div>
    <% } else { %>
      <div class="table-responsive rounded-3 border border-secondary border-opacity-10 shadow-lg" style="background-color: rgba(15, 23, 42, 0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <table class="table table-premium align-middle">
          <tbody>
            <% favorites.forEach(file => { %>
              <tr class="table-row-premium">
                
                <!-- Ícone & Link do Arquivo -->
                <td>
                  <a href="/shared/<%= file %>" target="_blank" class="d-flex align-items-center gap-3 text-white text-opacity-90 hover-text-white text-decoration-none truncate fw-semibold">
                    <!-- Ícone baseado na extensão -->
                    <i class="fs-5 flex-shrink-0 <%= file.match(/\.(jpg|jpeg|png|gif)$/i) ? 'bi bi-image text-primary-emphasis' : file.match(/\.(mp4|webm|ogg|mkv|mov)$/i) ? 'bi bi-film text-fuchsia-500' : file.match(/\.(mp3|wav|ogg|aac|flac)$/i) ? 'bi bi-music-note-beamed text-danger' : 'bi bi-file-earmark-arrow-down text-info' %>"></i>
                    <span class="text-truncate" title="<%= file %>"><%= file %></span>
                  </a>
                </td>

                <!-- Ações -->
                <td style="width: 120px;">
                  <div class="d-flex justify-content-end align-items-center gap-3">
                    <a href="/shared/<%= file %>" download class="text-secondary hover-text-white transition-all-200 text-decoration-none" title="Download">
                      <i class="bi bi-download fs-6"></i>
                    </a>
                    
                    <!-- Botão Remover do Favoritos (Desfavoritar) -->
                    <form action="/favorites/toggle" method="POST" class="m-0">
                      <input type="hidden" name="file" value="<%= file %>">
                      <button type="submit" class="btn btn-link p-0 text-warning hover-text-danger border-0 cursor-pointer" title="Remover dos favoritos">
                        <i class="bi bi-star-fill fs-5"></i>
                      </button>
                    </form>
                  </div>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    // Monitoramento do Input de Upload (para compatibilidade com header)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
      fileInput.addEventListener('change', function(e) {
        const info = document.getElementById('selectedFilesInfo');
        if (this.files && this.files.length > 0) {
          info.classList.remove('d-none');
          info.innerHTML = `<strong>Selecionados (${this.files.length}):</strong><ul class="list-unstyled mt-1 mb-0">${Array.from(this.files).map(f => `<li class="text-truncate" style="font-size: 11px;">• ${f.name}</li>`).join('')}</ul>`;
        } else {
          info.classList.add('d-none');
          info.innerHTML = '';
        }
      });
    }
  </script>

  <style>
    .select-files-box:hover .upload-icon {
      color: #7c3aed !important;
    }
    .select-files-box:hover {
      border-color: rgba(124, 58, 237, 0.4) !important;
      background-color: rgba(15, 23, 42, 0.4) !important;
    }
  </style>

</body>
</html>
