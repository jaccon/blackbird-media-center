<!-- Local stylesheets & script assets (Offline-capable & TV compatible) -->
<% if (typeof config !== 'undefined' && config.layoutFullWidth) { %>
<style>
  @media (min-width: 1200px) {
    .container-xl {
      max-width: 100% !important;
    }
    .kanban-column {
      max-width: none !important;
    }
  }
</style>
<% } %>

<% if (typeof config !== 'undefined' && config.theme) { %>
  <% if (config.theme === 'neon_midnight') { %>
    <style>
      /* Fundo da Página Geral */
      body, html, .bg-dark, .min-vh-screen, .app-container {
        background-color: #000000 !important;
        background: #000000 !important;
        background-image: radial-gradient(circle at top right, rgba(139, 92, 246, 0.12), transparent 45%), radial-gradient(circle at bottom left, rgba(236, 72, 153, 0.08), transparent 45%) !important;
        color: #f8fafc !important;
      }
      .bg-dark.bg-opacity-75, .bg-dark.bg-opacity-50, .bg-dark.bg-opacity-25, .bg-dark.bg-opacity-10 {
        background-color: #000000 !important;
      }
      
      /* Cards e Containers Principais */
      .card, .card-premium, .modal-content-premium, .offcanvas, .modal-content, .dropdown-menu {
        background: #050505 !important;
        background-color: #050505 !important;
        border: 1px solid rgba(139, 92, 246, 0.25) !important;
        box-shadow: 0 0 25px rgba(139, 92, 246, 0.05) !important;
        color: #f8fafc !important;
      }
      .card:hover, .card-premium:hover, .card-premium-action:hover {
        border-color: rgba(236, 72, 153, 0.5) !important;
        box-shadow: 0 0 30px rgba(236, 72, 153, 0.2) !important;
      }
      
      /* Substitui o tom azul marinho escuro inline por preto puro nos containers do sistema */
      [style*="background-color: rgba(15, 23, 42"], [style*="background: rgba(15, 23, 42"], .container-xl {
        background-color: #000000 !important;
        background: #000000 !important;
      }
      [style*="background-color: rgba(15, 23, 42, 0.25)"], [style*="background: rgba(15, 23, 42, 0.25)"],
      [style*="background-color: rgba(15, 23, 42, 0.3)"], [style*="background: rgba(15, 23, 42, 0.3)"] {
        background-color: #000000 !important;
        background: #000000 !important;
      }
      
      /* Header e Navegação */
      header, nav, .sticky-top {
        background-color: rgba(2, 2, 2, 0.95) !important;
        border-bottom: 1px solid rgba(139, 92, 246, 0.2) !important;
      }
      
      /* Links da barra de navegação */
      .nav-link-premium {
        color: #94a3b8 !important;
      }
      .nav-link-premium:hover {
        color: #ffffff !important;
        background-color: rgba(139, 92, 246, 0.15) !important;
        border-color: rgba(139, 92, 246, 0.4) !important;
      }
      .nav-link-premium.active {
        color: #ffffff !important;
        background: linear-gradient(to right, rgba(139, 92, 246, 0.25), rgba(236, 72, 153, 0.15)) !important;
        border: 1px solid rgba(139, 92, 246, 0.5) !important;
      }

      /* Formulários, Inputs e Caixas de Seleção */
      .input-premium, .form-control, .form-select {
        background-color: rgba(5, 5, 5, 0.95) !important;
        border: 1px solid rgba(139, 92, 246, 0.3) !important;
        color: #f8fafc !important;
      }
      .input-premium:focus, .form-control:focus, .form-select:focus {
        border-color: #ec4899 !important;
        box-shadow: 0 0 10px rgba(236, 72, 153, 0.25) !important;
      }
      
      /* Botões */
      .btn-premium-primary, .btn-primary {
        background: linear-gradient(to right, #8b5cf6, #ec4899) !important;
        color: #ffffff !important;
        box-shadow: 0 0 15px rgba(139, 92, 246, 0.3) !important;
        border: none !important;
      }
      .btn-premium-primary:hover, .btn-primary:hover {
        background: linear-gradient(to right, #ec4899, #8b5cf6) !important;
        box-shadow: 0 0 20px rgba(236, 72, 153, 0.5) !important;
        color: #ffffff !important;
      }
      .btn-premium-secondary, .btn-secondary {
        background: #0a0a0c !important;
        border: 1px solid rgba(139, 92, 246, 0.4) !important;
        color: #e2e8f0 !important;
      }
      .btn-premium-secondary:hover, .btn-secondary:hover {
        border-color: #ec4899 !important;
        color: #ffffff !important;
        box-shadow: 0 0 12px rgba(236, 72, 153, 0.2) !important;
      }
      
      /* Tabelas e Históricos */
      .table-premium, .table {
        background-color: transparent !important;
        color: #cbd5e1 !important;
      }
      .table-premium th, .table th, .table-dark th {
        background-color: rgba(139, 92, 246, 0.1) !important;
        border-bottom: 1px solid rgba(139, 92, 246, 0.3) !important;
        color: #a78bfa !important;
      }
      .table td, .table-dark td, .table-premium td {
        border-color: rgba(139, 92, 246, 0.15) !important;
        color: #cbd5e1 !important;
      }
      
      /* Elementos do Grid de Arquivos / Library */
      .video-card, .file-card, .folder-card {
        background-color: rgba(10, 10, 15, 0.75) !important;
        border: 1px solid rgba(139, 92, 246, 0.2) !important;
      }
      .video-card:hover, .file-card:hover, .folder-card:hover {
        border-color: #ec4899 !important;
        box-shadow: 0 0 15px rgba(236, 72, 153, 0.2) !important;
      }
      
      /* SweetAlert Modals */
      .swal2-popup {
        background: #08080a !important;
        border: 1px solid rgba(139, 92, 246, 0.3) !important;
        box-shadow: 0 0 25px rgba(139, 92, 246, 0.15) !important;
        color: #ffffff !important;
      }
      .swal2-title, .swal2-html-container {
        color: #ffffff !important;
      }
      
      /* Texto com gradiente e Badges */
      .text-gradient {
        background: linear-gradient(to right, #a78bfa, #ec4899) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
      }
      .badge, .tag-pill {
        border: 1px solid rgba(139, 92, 246, 0.35) !important;
        background-color: rgba(139, 92, 246, 0.12) !important;
        color: #a78bfa !important;
      }
    </style>
  <% } else if (config.theme === 'emerald_abyss') { %>
    <style>
      /* Fundo da Página Geral */
      body, html, .bg-dark, .min-vh-screen, .app-container {
        background-color: #020604 !important;
        background-image: radial-gradient(circle at top right, rgba(16, 185, 129, 0.12), transparent 45%), radial-gradient(circle at bottom left, rgba(6, 78, 59, 0.2), transparent 45%) !important;
        color: #f0fdf4 !important;
      }
      .bg-dark.bg-opacity-75, .bg-dark.bg-opacity-50, .bg-dark.bg-opacity-25, .bg-dark.bg-opacity-10 {
        background-color: #020604 !important;
      }
      
      /* Cards e Containers Principais */
      .card, .card-premium, .modal-content-premium, .offcanvas, .modal-content, .dropdown-menu {
        background: rgba(4, 15, 10, 0.95) !important;
        background-color: rgba(4, 15, 10, 0.95) !important;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        box-shadow: 0 0 25px rgba(16, 185, 129, 0.08) !important;
        color: #f0fdf4 !important;
      }
      .card:hover, .card-premium:hover, .card-premium-action:hover {
        border-color: rgba(52, 211, 153, 0.5) !important;
        box-shadow: 0 0 30px rgba(52, 211, 153, 0.2) !important;
      }
      
      /* Substitui o tom azul marinho escuro inline por verde esmeralda floresta nos containers do sistema */
      [style*="background-color: rgba(15, 23, 42"], [style*="background: rgba(15, 23, 42"], .container-xl {
        background-color: #020604 !important;
        background: #020604 !important;
      }
      [style*="background-color: rgba(15, 23, 42, 0.25)"], [style*="background: rgba(15, 23, 42, 0.25)"],
      [style*="background-color: rgba(15, 23, 42, 0.3)"], [style*="background: rgba(15, 23, 42, 0.3)"] {
        background-color: #020604 !important;
        background: #020604 !important;
      }
      
      /* Header e Navegação */
      header, nav, .sticky-top {
        background-color: rgba(2, 8, 5, 0.9) !important;
        border-bottom: 1px solid rgba(16, 185, 129, 0.25) !important;
      }
      
      /* Links da barra de navegação */
      .nav-link-premium {
        color: #94a3b8 !important;
      }
      .nav-link-premium:hover {
        color: #ffffff !important;
        background-color: rgba(16, 185, 129, 0.15) !important;
        border-color: rgba(16, 185, 129, 0.4) !important;
      }
      .nav-link-premium.active {
        color: #ffffff !important;
        background: linear-gradient(to right, rgba(16, 185, 129, 0.25), rgba(6, 78, 59, 0.15)) !important;
        border: 1px solid rgba(16, 185, 129, 0.5) !important;
      }

      /* Formulários, Inputs e Caixas de Seleção */
      .input-premium, .form-control, .form-select {
        background-color: rgba(2, 5, 3, 0.95) !important;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        color: #f0fdf4 !important;
      }
      .input-premium:focus, .form-control:focus, .form-select:focus {
        border-color: #34d399 !important;
        box-shadow: 0 0 10px rgba(52, 211, 153, 0.25) !important;
      }
      
      /* Botões */
      .btn-premium-primary, .btn-primary {
        background: linear-gradient(to right, #059669, #10b981) !important;
        color: #ffffff !important;
        box-shadow: 0 0 15px rgba(16, 185, 129, 0.3) !important;
        border: none !important;
      }
      .btn-premium-primary:hover, .btn-primary:hover {
        background: linear-gradient(to right, #10b981, #34d399) !important;
        box-shadow: 0 0 20px rgba(52, 211, 153, 0.5) !important;
        color: #ffffff !important;
      }
      .btn-premium-secondary, .btn-secondary {
        background: rgba(3, 8, 5, 0.9) !important;
        border: 1px solid rgba(16, 185, 129, 0.4) !important;
        color: #cbd5e1 !important;
      }
      .btn-premium-secondary:hover, .btn-secondary:hover {
        border-color: #34d399 !important;
        color: #ffffff !important;
        box-shadow: 0 0 12px rgba(52, 211, 153, 0.2) !important;
      }
      
      /* Tabelas e Históricos */
      .table-premium, .table {
        background-color: transparent !important;
        color: #cbd5e1 !important;
      }
      .table-premium th, .table th, .table-dark th {
        background-color: rgba(16, 185, 129, 0.1) !important;
        border-bottom: 1px solid rgba(16, 185, 129, 0.3) !important;
        color: #34d399 !important;
      }
      .table td, .table-dark td, .table-premium td {
        border-color: rgba(16, 185, 129, 0.15) !important;
        color: #cbd5e1 !important;
      }
      
      /* Elementos do Grid de Arquivos / Library */
      .video-card, .file-card, .folder-card {
        background-color: rgba(4, 10, 6, 0.75) !important;
        border: 1px solid rgba(16, 185, 129, 0.2) !important;
      }
      .video-card:hover, .file-card:hover, .folder-card:hover {
        border-color: #34d399 !important;
        box-shadow: 0 0 15px rgba(52, 211, 153, 0.2) !important;
      }
      
      /* SweetAlert Modals */
      .swal2-popup {
        background: #030a06 !important;
        border: 1px solid rgba(16, 185, 129, 0.3) !important;
        box-shadow: 0 0 25px rgba(16, 185, 129, 0.15) !important;
        color: #ffffff !important;
      }
      .swal2-title, .swal2-html-container {
        color: #ffffff !important;
      }
      
      /* Texto com gradiente e Badges */
      .text-gradient {
        background: linear-gradient(to right, #34d399, #10b981) !important;
        -webkit-background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
      }
      .badge, .tag-pill {
        border: 1px solid rgba(16, 185, 129, 0.35) !important;
        background-color: rgba(16, 185, 129, 0.12) !important;
        color: #34d399 !important;
      }
    </style>
  <% } %>
<% } %>

<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap"
  rel="stylesheet">
<link rel="stylesheet" href="/css/bootstrap-icons.css">
<link rel="stylesheet" href="/css/styles.css">
<script src="/js/qrcode.min.js"></script>

<!-- Header Principal -->
<header class="w-100 border-bottom border-secondary border-opacity-10 bg-dark bg-opacity-75 sticky-top z-3"
  style="backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); height: 80px;">
  <div class="container-xl h-100 d-flex align-items-center justify-content-between px-3">

    <!-- Logotipo Black Bird -->
    <a href="/" class="d-flex align-items-center gap-3 text-decoration-none group">
      <div class="d-flex align-items-center justify-content-center">
        <!-- Bird SVG Logo -->
        <img src="/images/logo.svg" class="object-contain transition-all-200" style="width: 36px; height: 36px;"
          alt="Logo">
      </div>
      <div class="d-flex flex-column">
        <span class="fs-5 fw-bold tracking-tight text-white leading-none font-outfit m-0">
          Black <span class="text-gradient">Bird</span>
        </span>
        <span class="text-uppercase text-secondary fw-semibold tracking-widest m-0"
          style="font-size: 10px; margin-top: 2px !important;">Media Center</span>
      </div>
    </a>

    <!-- Botões de Ação e QR Code -->
    <div class="d-flex align-items-center gap-3">
      <!-- Botões de Ação -->
      <div class="d-flex align-items-center gap-2">
        <button onclick="toggleUploadModal()" class="btn btn-premium-primary d-flex align-items-center gap-2 border-0">
          <i class="bi bi-cloud-arrow-up fs-6"></i>
          <span class="d-none d-sm-inline"><%= t('upload_files') %></span>
        </button>
        <button onclick="toggleCreateFolderModal()" class="btn btn-premium-secondary d-flex align-items-center gap-2">
          <i class="bi bi-folder-plus fs-6 text-secondary"></i>
          <span class="d-none d-sm-inline"><%= t('create_folder') %></span>
        </button>
      </div>

      <!-- Divisor -->
      <div class="vr bg-secondary opacity-25" style="height: 32px;"></div>

      <!-- Container do QR Code -->
      <div class="position-relative group">
        <div id="qrcode"
          class="p-1 bg-dark bg-opacity-50 border border-secondary border-opacity-10 rounded cursor-pointer"
          style="width: 44px; height: 44px; overflow: hidden;"></div>
      </div>
    </div>

  </div>
</header>

<!-- Submenu / Navegação de Seções -->
<nav class="w-100 bg-dark bg-opacity-25 border-bottom border-secondary border-opacity-10 py-2">
  <div class="container-xl d-flex align-items-center px-3">
    <!-- Links Principais -->
    <div class="d-flex flex-wrap align-items-center gap-1 flex-fill">
      <a href="/dashboard" class="nav-link-premium text-decoration-none" style="font-size: 13px;">
        <i class="bi bi-speedometer2 text-info"></i>
        <span><%= t('dashboard') %></span>
      </a>

      <!-- Dropdown Files -->
      <div class="dropdown d-inline-block">
        <button class="nav-link-premium text-decoration-none bg-transparent border-0 dropdown-toggle" type="button" id="dropdownFiles" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 13px; outline: none; box-shadow: none;">
          <i class="bi bi-folder2-open text-warning"></i>
          <span><%= t('files') %></span>
        </button>
        <ul class="dropdown-menu dropdown-menu-dark border border-secondary border-opacity-10 bg-dark shadow-lg animate" aria-labelledby="dropdownFiles">
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/videos" style="font-size: 13px;">
              <i class="bi bi-film text-fuchsia-500 fs-6"></i>
              <span><%= t('videos') %></span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/photos" style="font-size: 13px;">
              <i class="bi bi-image text-primary-emphasis fs-6"></i>
              <span><%= t('photos') %></span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/music" style="font-size: 13px;">
              <i class="bi bi-music-note-beamed text-danger fs-6"></i>
              <span><%= t('music') %></span>
            </a>
          </li>
          <li>
            <hr class="dropdown-divider border-secondary border-opacity-20 my-1">
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/explorer" style="font-size: 13px;">
              <i class="bi bi-folder2 text-warning fs-6"></i>
              <span>Explorer</span>
            </a>
          </li>
        </ul>
      </div>

      <a href="/favorites" class="nav-link-premium text-decoration-none" style="font-size: 13px;">
        <i class="bi bi-star text-warning"></i>
        <span><%= t('favorites') %></span>
      </a>

      <!-- Dropdown Applications -->
      <div class="dropdown d-inline-block">
        <button class="nav-link-premium text-decoration-none bg-transparent border-0 dropdown-toggle" type="button" id="dropdownApplications" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 13px; outline: none; box-shadow: none;">
          <i class="bi bi-grid-fill text-fuchsia-500"></i>
          <span>Applications</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-dark border border-secondary border-opacity-10 bg-dark shadow-lg animate" aria-labelledby="dropdownApplications">
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/cameras" style="font-size: 13px;">
              <i class="bi bi-camera-video text-secondary fs-6"></i>
              <span>Cameras</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/home-control" style="font-size: 13px;">
              <i class="bi bi-house-gear text-fuchsia-500 fs-6"></i>
              <span><%= t('home_control') %></span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/notes" style="font-size: 13px;">
              <i class="bi bi-sticky text-warning fs-6"></i>
              <span>Notes</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/ai" style="font-size: 13px;">
              <i class="bi bi-chat-dots text-primary fs-6"></i>
              <span>AI</span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/tasks" style="font-size: 13px;">
              <i class="bi bi-kanban text-info fs-6"></i>
              <span><%= t('tasks') %></span>
            </a>
          </li>
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/localization" style="font-size: 13px;">
              <i class="bi bi-geo-alt-fill text-gradient fs-6"></i>
              <span>Localization</span>
            </a>
          </li>
        </ul>
      </div>

      <!-- Dropdown Setup -->
      <div class="dropdown d-inline-block">
        <button class="nav-link-premium text-decoration-none bg-transparent border-0 dropdown-toggle" type="button" id="dropdownSetup" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 13px; outline: none; box-shadow: none;">
          <i class="bi bi-sliders text-gradient"></i>
          <span>Setup</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-dark border border-secondary border-opacity-10 bg-dark shadow-lg animate" aria-labelledby="dropdownSetup">
          <li>
            <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/settings" style="font-size: 13px;">
              <i class="bi bi-gear text-info fs-6"></i>
              <span>Settings</span>
            </a>
          </li>
          <% if (typeof userGroup !== 'undefined' && userGroup === 'admin') { %>
            <li>
              <a class="dropdown-item d-flex align-items-center gap-2 font-outfit py-2" href="/users" style="font-size: 13px;">
                <i class="bi bi-people text-success fs-6"></i>
                <span>Users</span>
              </a>
            </li>
          <% } %>
        </ul>
      </div>

      <a href="/remote" class="nav-link-premium text-decoration-none d-flex d-lg-none" style="font-size: 13px;">
        <i class="bi bi-controller text-gradient"></i>
        <span><%= t('remote_control') %></span>
      </a>
      <!-- Notification Icon Bell -->
      <% 
        const unreadCount = typeof notifications !== 'undefined' ? notifications.filter(n => !n.read).length : 0;
      %>
      <a href="/notifications" class="nav-link-premium text-decoration-none d-flex align-items-center gap-1.5 position-relative" style="font-size: 13px;">
        <i class="bi bi-bell-fill text-warning"></i>
        <span><%= t('notifications') %></span>
        <% if (unreadCount > 0) { %>
          <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-dark" style="font-size: 8px; padding: 0.25em 0.5em;">
            <%= unreadCount %>
          </span>
        <% } %>
      </a>

      <button id="sidebarChatToggleBtn" class="nav-link-premium text-decoration-none bg-transparent border-0 d-flex align-items-center gap-2" style="font-size: 13px; outline: none; box-shadow: none;">
        <i class="bi bi-robot text-primary"></i>
        <span><%= t('chat_ai') %></span>
      </button>
      <% if (typeof config !== 'undefined' && config.authEnabled) { %>
        <% if (typeof username !== 'undefined' && username) { %>
          <span class="nav-link-premium text-decoration-none border-0 text-secondary pe-none ms-md-auto" style="font-size: 13px;">
            <i class="bi bi-person-fill text-gradient"></i>
            <span><%= username %></span>
          </span>
        <% } %>
        <a href="/logout" class="nav-link-premium text-decoration-none text-danger hover-text-danger" style="font-size: 13px; <%= (typeof username !== 'undefined' && username) ? 'margin-left: 1rem !important;' : 'margin-left: auto !important;' %>">
          <i class="bi bi-box-arrow-right text-danger"></i>
          <span><%= t('logout') %></span>
        </a>
      <% } %>

    </div>
  </div>
</nav>

<!-- Barra de Pesquisa Global (Fora do Menu) -->
<div class="w-100 bg-dark bg-opacity-10 border-bottom border-secondary border-opacity-10 py-2">
  <div class="container-xl px-3 position-relative">
    <form action="/explorer" method="GET" class="position-relative m-0 w-100">
      <input type="text" name="search" id="globalSearchInput" placeholder="<%= t('search_placeholder') %>"
        value="<%= typeof search !== 'undefined' ? search : '' %>" class="form-control input-premium w-100"
        style="padding-left: 2.5rem !important;" autocomplete="off">
      <i class="bi bi-search position-absolute text-secondary"
        style="left: 16px; top: 50%; transform: translateY(-50%); font-size: 13px;"></i>
      <div id="searchSuggestionsDropdown" class="search-suggestions-dropdown d-none"></div>
    </form>
