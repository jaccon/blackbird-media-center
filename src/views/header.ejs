<script>
  (function() {
    const toggleBtn = document.getElementById('sidebarChatToggleBtn');
    const sidebar = document.getElementById('aiChatSidebar');
    const closeBtn = document.getElementById('aiChatSidebarCloseBtn');
    const form = document.getElementById('aiChatSidebarForm');
    const input = document.getElementById('aiChatSidebarInput');
    const messagesContainer = document.getElementById('aiChatSidebarMessages');

    let isOpen = false;
    let historyLoaded = false;

    function loadHistoryFromAPI() {
      if (historyLoaded) return;
      fetch('/api/chat/history')
        .then(res => res.json())
        .then(data => {
          if (data.success && data.history && data.history.length > 0) {
            messagesContainer.innerHTML = '';
            data.history.forEach(msg => {
              // Create message element manually to avoid infinite loop calling appendMessage
              const messageDiv = document.createElement('div');
              messageDiv.className = 'ai-message ' + (msg.role === 'user' ? 'outgoing' : 'incoming');
              
              const now = msg.timestamp ? new Date(msg.timestamp) : new Date();
              const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
              
              messageDiv.innerHTML = `
                <div class="ai-msg-bubble">
                  ${msg.role === 'user' ? escapeHtml(msg.content) : formatResponse(msg.content)}
                </div>
                <span class="time">${timeString}</span>
              `;
              messagesContainer.appendChild(messageDiv);
            });
            scrollToBottom();
            historyLoaded = true;
          }
        })
        .catch(err => console.error('Erro ao carregar histórico do chat:', err));
    }

    if (!toggleBtn || !sidebar) return;

    // Toggle click handler
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      e.preventDefault();
      if (isOpen) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    // Close click handler
    if (closeBtn) {
      closeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        closeSidebar();
      });
    }

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (isOpen && !sidebar.contains(e.target) && !toggleBtn.contains(e.target)) {
        closeSidebar();
      }
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeSidebar();
      }
    });

    function openSidebar() {
      isOpen = true;
      sidebar.classList.add('show');
      sidebar.setAttribute('aria-hidden', 'false');
      toggleBtn.classList.add('active');
      loadHistoryFromAPI();
      setTimeout(() => {
        if (input) input.focus();
      }, 300);
      scrollToBottom();
    }

    function closeSidebar() {
      isOpen = false;
      sidebar.classList.remove('show');
      sidebar.setAttribute('aria-hidden', 'true');
      toggleBtn.classList.remove('active');
    }

    // Form submit handler
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        handleMessageSubmit();
      });
    }

    function handleMessageSubmit() {
      const text = input.value.trim();
      if (!text) return;

      // Add user message
      appendMessage('user', text);
      input.value = '';

      // Show typing indicator
      showTypingIndicator();

      // Fetch AI response
      fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text })
      })
      .then(res => res.json())
      .then(data => {
        removeTypingIndicator();
        if (data.success) {
          appendMessage('ai', data.response);
          if (data.refreshTasks && window.location.pathname === '/tasks') {
            setTimeout(() => {
              window.location.reload();
            }, 1000);
          }
        } else {
          appendMessage('ai', 'Erro ao obter resposta da AI: ' + data.error);
        }
      })
      .catch(err => {
        removeTypingIndicator();
        console.error(err);
        appendMessage('ai', 'Erro ao conectar ao servidor.');
      });
    }

    function appendMessage(sender, text) {
      const messageDiv = document.createElement('div');
      messageDiv.classList.add('ai-message');
      if (sender === 'user') {
        messageDiv.classList.add('outgoing');
      } else {
        messageDiv.classList.add('incoming');
      }

      const now = new Date();
      const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

      let contentHtml = '';
      if (sender === 'user') {
        contentHtml = `
          <div class="ai-msg-bubble">
            ${escapeHtml(text)}
          </div>
          <span class="time">${timeString}</span>
        `;
      } else {
        contentHtml = `
          <div class="ai-msg-bubble">
            ${formatResponse(text)}
          </div>
          <span class="time">${timeString}</span>
        `;
      }

      messageDiv.innerHTML = contentHtml;
      messagesContainer.appendChild(messageDiv);
      scrollToBottom();
    }

    function showTypingIndicator() {
      const indicator = document.createElement('div');
      indicator.classList.add('ai-message', 'incoming');
      indicator.id = 'aiTypingIndicator';
      indicator.innerHTML = `
        <div class="ai-msg-bubble">
          <div class="ai-typing-indicator">
            <div class="ai-typing-dot"></div>
            <div class="ai-typing-dot"></div>
            <div class="ai-typing-dot"></div>
          </div>
        </div>
      `;
      messagesContainer.appendChild(indicator);
      scrollToBottom();
    }

    function removeTypingIndicator() {
      const indicator = document.getElementById('aiTypingIndicator');
      if (indicator) {
        indicator.remove();
      }
    }

    function scrollToBottom() {
      if (messagesContainer) {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }
    }

    function escapeHtml(str) {
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }

    function formatResponse(text) {
      // Escape basic HTML
      let formatted = text
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

      // Code blocks
      formatted = formatted.replace(/```([\s\S]+?)```/g, function(match, code) {
        return '<pre><code>' + code.trim() + '</code></pre>';
      });

      // Bold
      formatted = formatted.replace(/\*\*([\s\S]+?)\*\*/g, '<strong>$1</strong>');

      // New lines
      formatted = formatted.replace(/\n/g, '<br>');

      return formatted;
    }

    // Lembrete / Alerta proativo do Chat AI
    setTimeout(() => {
      if (sessionStorage.getItem('aiAlertInit') !== 'true') {
        fetch('/api/tasks/alerts')
          .then(res => res.json())
          .then(data => {
            if (data.showAlert && data.message) {
              sessionStorage.setItem('aiAlertInit', 'true');
              
              // Abrir a sidebar e carregar histórico
              openSidebar();
            }
          })
          .catch(err => console.error('Erro ao buscar alertas da AI:', err));
      }
    }, 2000);
  })();
</script>

<script>
  (function() {
    const searchInput = document.getElementById('globalSearchInput');
    const dropdown = document.getElementById('searchSuggestionsDropdown');
    let debounceTimeout;

    if (!searchInput || !dropdown) return;

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimeout);
      const query = searchInput.value.trim();

      if (query.length < 2) {
        dropdown.classList.add('d-none');
        dropdown.innerHTML = '';
        return;
      }

      debounceTimeout = setTimeout(() => {
        fetch(`/api/search/suggestions?q=${encodeURIComponent(query)}`)
          .then(res => res.json())
          .then(data => {
            if (data.success && data.suggestions && data.suggestions.length > 0) {
               renderSuggestions(data.suggestions);
            } else {
               dropdown.classList.add('d-none');
               dropdown.innerHTML = '';
            }
          })
          .catch(err => {
            console.error('Error fetching suggestions:', err);
          });
      }, 300); // 300ms debounce
    });

    function renderSuggestions(suggestions) {
      dropdown.innerHTML = '';
      suggestions.forEach(item => {
        const div = document.createElement('a');
        div.className = 'suggestion-item';
        
        let icon = 'bi-file-earmark-fill';
        let pathUrl = `/explorer?search=${encodeURIComponent(item.name)}`;
        
        const ext = item.type;
        if (['mp4', 'mkv', 'avi', 'mov', 'webm'].includes(ext)) {
          icon = 'bi-film text-fuchsia-500';
          pathUrl = `/play?video=${encodeURIComponent(item.path)}`;
        } else if (['mp3', 'wav', 'ogg', 'aac'].includes(ext)) {
          icon = 'bi-music-note-beamed text-danger';
          pathUrl = `/shared/${encodeURIComponent(item.path)}`;
        } else if (['jpg', 'jpeg', 'png', 'gif', 'svg'].includes(ext)) {
          icon = 'bi-image text-primary-emphasis';
          pathUrl = `/shared/${encodeURIComponent(item.path)}`;
        } else if (ext === 'pdf') {
          icon = 'bi-file-pdf text-danger';
          pathUrl = `/shared/${encodeURIComponent(item.path)}`;
        }
        
        div.href = pathUrl;
        div.innerHTML = `
          <i class="bi ${icon} suggestion-icon"></i>
          <span class="suggestion-text">${escapeHtml(item.name)}</span>
          <span class="suggestion-path">${escapeHtml(item.path.split('/').slice(0, -1).join('/') || '/')}</span>
        `;
        
        dropdown.appendChild(div);
      });
      dropdown.classList.remove('d-none');
    }

    // Hide suggestions when clicking outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add('d-none');
      }
    });

    // Show suggestions if input is focused and contains query
    searchInput.addEventListener('focus', () => {
      if (searchInput.value.trim().length >= 2 && dropdown.children.length > 0) {
        dropdown.classList.remove('d-none');
      }
    });

    function escapeHtml(str) {
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }
  })();
</script>