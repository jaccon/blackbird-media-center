<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Área Oculta - Black Bird Media Center</title>
</head>
<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) (Bootstrap 5) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
          <div id="selectedFilesInfo" class="small text-secondary mt-3 p-3 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10 d-none" style="max-height: 110px; overflow-y: auto;"></div>
        </div>
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xl py-4 px-3">
    
    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="fs-4 fw-bold text-white font-outfit m-0"><%= t('hidden_files') %></h2>
        <p class="text-secondary small m-0 mt-1"><%= t('hidden_files_desc') %></p>
      </div>
      <a href="/" class="btn btn-sm btn-premium-secondary border-0 d-flex align-items-center gap-1.5 py-1.5 px-3">
        <i class="bi bi-arrow-left fs-6"></i>
        <span><%= t('back_to_dashboard') %></span>
      </a>
    </div>

    <!-- Lista de Ocultos -->
    <% if (contents.length === 0) { %>
      <div class="text-center py-5 rounded-3 border border-secondary border-opacity-10" style="background-color: rgba(15, 23, 42, 0.25);">
        <i class="bi bi-eye text-secondary block mb-3 d-block mx-auto" style="font-size: 3rem;"></i>
        <h3 class="fs-5 fw-bold text-white font-outfit">Nenhum arquivo ocultado</h3>
        <p class="text-secondary small mt-1 max-w-sm mx-auto mb-3">Você pode ocultar arquivos no File Manager ou nas bibliotecas usando o botão de ocultar (<i class="bi bi-eye-slash"></i>).</p>
      </div>
    <% } else { %>
      <div class="table-responsive rounded-3 border border-secondary border-opacity-10 shadow-lg" style="background-color: rgba(15, 23, 42, 0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
        <table class="table table-premium align-middle">
          <tbody>
            <% contents.forEach(item => { %>
              <tr class="table-row-premium">
                
                <!-- Nome, Ícone & Link -->
                <td>
                  <% const isVideo = item.isFile ? item.name.match(/\.(mp4|webm|ogg|mkv|mov)$/i) : false; %>
                  <% if (!item.isFile) { %>
                    <a href="/explorer?path=<%= encodeURIComponent(item.path) %>" 
                       class="d-flex align-items-center gap-3 text-white text-opacity-90 hover-text-white text-decoration-none truncate fw-semibold">
                      <i class="fs-5 flex-shrink-0 bi bi-folder-fill text-warning"></i>
                      <span class="text-truncate" title="<%= item.name %>"><%= item.name %></span>
                    </a>
                  <% } else { %>
                    <a href="<%= isVideo ? `/play?video=${encodeURIComponent(item.path)}` : `/shared/${encodeURIComponent(item.path)}` %>" 
                       <%= isVideo ? '' : 'target="_blank"' %> 
                       class="d-flex align-items-center gap-3 text-white text-opacity-90 hover-text-white text-decoration-none truncate fw-semibold">
                      <i class="fs-5 flex-shrink-0 <%= item.name.match(/\.(jpg|jpeg|png|gif)$/i) ? 'bi bi-image text-primary-emphasis' : isVideo ? 'bi bi-film text-fuchsia-500' : item.name.match(/\.(mp3|wav|ogg|aac|flac)$/i) ? 'bi bi-music-note-beamed text-danger' : 'bi bi-file-earmark-arrow-down text-info' %>"></i>
                      <span class="text-truncate" title="<%= item.name %>"><%= item.name %></span>
                    </a>
                  <% } %>
                </td>

                <!-- Tamanho -->
                <td class="text-secondary small font-mono text-end" style="width: 150px;">
                  <% if (item.isFile) { %>
                    <%= (item.size / 1024).toFixed(2) %> KB
                  <% } else { %>
                    Diretório
                  <% } %>
                </td>

                <!-- Ações -->
                <td style="width: 120px;">
                  <div class="d-flex justify-content-end align-items-center gap-3">
                    <% if (item.isFile) { %>
                      <a href="/shared/<%= encodeURIComponent(item.path) %>" download class="text-secondary hover-text-white transition-all-200 text-decoration-none" title="Download">
                        <i class="bi bi-download fs-6"></i>
                      </a>
                    <% } %>
                    
                    <!-- Botão Remover da Área Oculta (Desocultar) -->
                    <form action="/hide/toggle" method="POST" class="m-0">
                      <input type="hidden" name="file" value="<%= item.path %>">
                      <button type="submit" class="btn btn-link p-0 text-success hover-text-danger border-0 cursor-pointer" title="Desocultar arquivo">
                        <i class="bi bi-eye fs-5"></i>
                      </button>
                    </form>
                  </div>
                </td>

              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>

  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
      fileInput.addEventListener('change', function() {
        const info = document.getElementById('selectedFilesInfo');
        if (info) {
          info.classList.remove('d-none');
          info.innerHTML = Array.from(fileInput.files).map(f => f.name).join('<br>');
        }
      });
    }
  </script>
</body>
</html>
