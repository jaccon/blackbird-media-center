<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reproduzindo Vídeo - Black Bird Media Center</title>
</head>
<body class="bg-dark text-light min-vh-screen d-flex flex-column">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) (Bootstrap 5) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <!-- Modal Header -->
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <!-- Modal Body -->
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
          <div id="selectedFilesInfo" class="small text-secondary mt-3 p-3 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10 d-none" style="max-height: 110px; overflow-y: auto;"></div>
        </div>
        <!-- Modal Footer -->
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Container -->
  <main class="flex-grow-1 container-xl py-4 px-3 d-flex flex-column gap-4" style="max-width: 960px;">
    
    <!-- Breadcrumb e Botão Voltar -->
    <div class="d-flex justify-content-between align-items-center bg-dark bg-opacity-25 border border-secondary border-opacity-10 rounded-3 p-3">
      <div class="d-flex align-items-center gap-2 text-secondary small fw-medium">
        <i class="bi bi-film text-fuchsia-500 fs-5"></i>
        <a href="/explorer" class="text-secondary hover-text-white text-decoration-none transition-all-200">Raiz</a>
        <% 
          const parts = video.split('/');
          const filename = parts.pop();
          const parentPath = parts.join('/');
          const backUrl = parentPath ? `/explorer?path=${encodeURIComponent(parentPath)}` : '/explorer';
        %>
        <% parts.forEach((part, index) => { %>
          <i class="bi bi-chevron-right text-secondary text-opacity-25" style="font-size: 10px;"></i>
          <a href="/explorer?path=<%= encodeURIComponent(parts.slice(0, index + 1).join('/')) %>" class="text-secondary hover-text-white text-decoration-none transition-all-200"><%= part %></a>
        <% }) %>
        <i class="bi bi-chevron-right text-secondary text-opacity-25" style="font-size: 10px;"></i>
        <span class="text-white truncate font-outfit fw-bold max-w-200" title="<%= filename %>"><%= filename %></span>
      </div>

      <a href="<%= backUrl %>" class="btn btn-sm btn-premium-secondary d-flex align-items-center gap-2 text-decoration-none">
        <i class="bi bi-arrow-left"></i>
        <span>Voltar</span>
      </a>
    </div>

    <!-- Container do Player -->
    <div class="ratio ratio-16x9 bg-black rounded-3 overflow-hidden border border-secondary border-opacity-10 shadow-lg position-relative">
      
      <!-- Detecção do formato para renderização dinâmica -->
      <% 
        const isMkv = video.toLowerCase().endsWith('.mkv');
        const videoSrc = isMkv 
          ? `/stream-video?file=${encodeURIComponent(video)}` 
          : `/shared/${encodeURIComponent(video)}`;
      %>

      <!-- Video Player -->
      <video id="mediaPlayer" controls autoplay class="w-100 h-100 object-contain focus-outline-none" style="object-fit: contain;">
        <source src="<%= videoSrc %>" type="<%= isMkv ? 'video/mp4' : 'video/mp4' %>">
        Seu navegador não suporta a tag de vídeo HTML5.
      </video>

      <!-- Overlay Indicador de Transcodificação para MKV -->
      <% if (isMkv) { %>
        <div id="transcodeBadge" class="position-absolute top-0 start-0 m-3 z-3 d-flex align-items-center gap-1.5 px-3 py-1 rounded-pill bg-fuchsia-600 bg-opacity-90 text-white font-mono text-uppercase fw-bold select-none pointer-events-none" style="font-size: 10px; box-shadow: 0 0 10px rgba(217, 70, 239, 0.4);">
          <span class="pulse-indicator m-0" style="background-color: #fff;"></span>
          Transcoding ao vivo (MKV)
        </div>
      <% } %>

    </div>

    <!-- Detalhes do Arquivo e Dicas -->
    <div class="row g-4">
      
      <!-- Informações do Vídeo -->
      <div class="col-12 col-md-6">
        <div class="bg-dark bg-opacity-25 border border-secondary border-opacity-10 rounded-3 p-4 h-100">
          <h3 class="fs-6 fw-bold text-white font-outfit mb-3 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle text-fuchsia-500"></i>
            Informações da Mídia
          </h3>
          <ul class="list-unstyled space-y-2 m-0 text-secondary small">
            <li class="d-flex justify-content-between border-bottom border-secondary border-opacity-10 pb-2 mb-2">
              <span>Nome do arquivo:</span>
              <span class="text-light font-mono text-truncate max-w-350" title="<%= filename %>"><%= filename %></span>
            </li>
            <li class="d-flex justify-content-between border-bottom border-secondary border-opacity-10 pb-2 mb-2">
              <span>Caminho relativo:</span>
              <span class="text-light font-mono text-truncate max-w-350" title="<%= video %>"><%= video %></span>
            </li>
            <li class="d-flex justify-content-between">
              <span>Formato detectado:</span>
              <span class="text-fuchsia-400 fw-bold uppercase"><%= isMkv ? 'Matroska Video (MKV)' : 'Nativo do Navegador (MP4/WebM)' %></span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Legendas do Filme -->
      <div class="col-12 col-md-6">
        <div class="bg-dark bg-opacity-25 border border-secondary border-opacity-10 rounded-3 p-4 h-100 d-flex flex-column justify-content-between">
          <div>
            <h3 class="fs-6 fw-bold text-white font-outfit mb-3 d-flex align-items-center gap-2">
              <i class="bi bi-file-earmark-text text-fuchsia-500"></i>
              Legendas (Subtitles)
            </h3>
            
            <div id="subtitlesList" class="mb-3">
              <% if (typeof subtitles !== 'undefined' && subtitles.length > 0) { %>
                <p class="text-secondary small mb-2">Legendas encontradas no servidor:</p>
                <div class="d-flex flex-column gap-2 mb-3" style="max-height: 120px; overflow-y: auto;">
                  <% subtitles.forEach((sub, idx) => { %>
                    <button type="button" onclick="loadServerSubtitle('<%= encodeURIComponent(sub.path) %>', '<%= sub.name %>')" class="btn btn-sm btn-premium-secondary border-0 d-flex align-items-center justify-content-between py-2 px-3 text-start">
                      <span class="text-truncate fw-semibold text-light" style="max-width: 250px;"><i class="bi bi-hdd-network text-info me-2"></i><%= sub.name %></span>
                      <span class="badge bg-secondary bg-opacity-25 text-secondary text-uppercase small" style="font-size: 9px;"><%= sub.ext.replace('.', '') %></span>
                    </button>
                  <% }) %>
                </div>
              <% } else { %>
                <p class="text-secondary small mb-3">Nenhuma legenda encontrada automaticamente no servidor.</p>
              <% } %>
            </div>
            
            <div class="d-flex flex-wrap gap-2">
              <!-- Upload/Seleção de Legenda Local -->
              <input type="file" id="subtitleInput" accept=".srt,.vtt" class="d-none">
              <button type="button" onclick="document.getElementById('subtitleInput').click()" class="btn btn-sm btn-premium-primary border-0 d-flex align-items-center gap-2 py-2 px-3">
                <i class="bi bi-file-earmark-arrow-up"></i>
                <span>Carregar Legenda Local</span>
              </button>
              
              <!-- Desativar Legendas -->
              <button type="button" onclick="disableSubtitles()" id="disableSubsBtn" class="btn btn-sm btn-premium-secondary border-0 d-flex align-items-center gap-2 py-2 px-3 d-none">
                <i class="bi bi-eye-slash text-danger"></i>
                <span>Desativar Legendas</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Dicas de Reprodução e Ações de Ocultar -->
      <div class="col-12 col-md-12">
        <div class="bg-dark bg-opacity-25 border border-secondary border-opacity-10 rounded-3 p-4 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3">
          <div class="flex-grow-1" style="max-width: 600px;">
            <h4 class="text-uppercase text-fuchsia-500 fw-semibold tracking-wider mb-1 font-outfit" style="font-size: 11px;">Reprodução de MKV & Legendas</h4>
            <p class="text-secondary small leading-relaxed m-0" style="font-size: 12px;">
              Arquivos MKV usam transcoding em tempo real. Você pode carregar legendas do seu computador (.srt ou .vtt) ou colocar o arquivo de legenda na mesma pasta do vídeo com o mesmo nome para carregamento automático.
            </p>
          </div>
          <div class="d-flex flex-column gap-2 flex-shrink-0" style="min-width: 180px;">
            <form action="/hide/toggle" method="POST" class="m-0">
              <input type="hidden" name="file" value="<%= video %>">
              <button type="submit" class="btn btn-sm btn-premium-secondary border-0 w-100 d-flex align-items-center justify-content-center gap-1.5 py-2 px-3">
                <i class="bi bi-eye-slash text-danger"></i>
                <span>Ocultar Vídeo</span>
              </button>
            </form>
            <span class="text-success fw-bold d-flex align-items-center justify-content-center gap-1.5 small mt-1">
              <span class="pulse-indicator m-0" style="background-color: #10b981; width: 6px; height: 6px;"></span>
              Pronto para assistir
            </span>
          </div>
        </div>
      </div>

    </div>

  </main>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    // Conversor de SRT para WebVTT
    function srt2webvtt(srt) {
      var vtt = srt.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
      // Substitui vírgula por ponto nos timecodes
      vtt = vtt.replace(/(\d{2}:\d{2}:\d{2}),(\d{3})/g, '$1.$2');
      return "WEBVTT\n\n" + vtt;
    }

    // Carregar Legenda do Servidor
    function loadServerSubtitle(subPath, subName) {
      var video = document.getElementById('mediaPlayer');
      var url = '/subtitles/vtt?file=' + subPath;

      // Remover tracks anteriores
      var existingTracks = video.querySelectorAll('track');
      existingTracks.forEach(t => t.remove());

      var track = document.createElement('track');
      track.kind = 'subtitles';
      track.label = subName;
      track.srclang = 'pt';
      track.src = url;
      track.default = true;

      video.appendChild(track);
      document.getElementById('disableSubsBtn').classList.remove('d-none');

      Swal.fire({
        title: 'Legenda Carregada!',
        text: 'A legenda do servidor "' + subName + '" está ativa.',
        icon: 'success',
        timer: 2000,
        showConfirmButton: false,
        background: '#0f172a',
        color: '#f8fafc'
      });
    }

    // Desativar Legendas
    function disableSubtitles() {
      var video = document.getElementById('mediaPlayer');
      var existingTracks = video.querySelectorAll('track');
      existingTracks.forEach(t => t.remove());
      
      document.getElementById('disableSubsBtn').classList.add('d-none');
      if (document.getElementById('subtitleInput')) {
        document.getElementById('subtitleInput').value = '';
      }

      Swal.fire({
        title: 'Legendas Desativadas',
        icon: 'info',
        timer: 1500,
        showConfirmButton: false,
        background: '#0f172a',
        color: '#f8fafc'
      });
    }

    // Monitorar input de legenda local
    document.getElementById('subtitleInput').addEventListener('change', function(e) {
      var file = e.target.files[0];
      if (!file) return;

      var reader = new FileReader();
      reader.onload = function(evt) {
        var text = evt.target.result;
        var vttText = text;
        if (file.name.endsWith('.srt')) {
          vttText = srt2webvtt(text);
        }

        var blob = new Blob([vttText], { type: 'text/vtt' });
        var url = URL.createObjectURL(blob);

        var video = document.getElementById('mediaPlayer');
        var existingTracks = video.querySelectorAll('track');
        existingTracks.forEach(t => t.remove());

        var track = document.createElement('track');
        track.kind = 'subtitles';
        track.label = file.name;
        track.srclang = 'pt';
        track.src = url;
        track.default = true;

        video.appendChild(track);
        document.getElementById('disableSubsBtn').classList.remove('d-none');

        Swal.fire({
          title: 'Legenda Carregada!',
          text: 'Legenda local "' + file.name + '" ativa.',
          icon: 'success',
          timer: 2000,
          showConfirmButton: false,
          background: '#0f172a',
          color: '#f8fafc'
        });
      };
      reader.readAsText(file);
    });

    // Monitoramento do Input de Upload (para compatibilidade com header)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
      fileInput.addEventListener('change', function(e) {
        const info = document.getElementById('selectedFilesInfo');
        if (this.files && this.files.length > 0) {
          info.classList.remove('d-none');
          info.innerHTML = `<strong>Selecionados (${this.files.length}):</strong><ul class="list-unstyled mt-1 mb-0">${Array.from(this.files).map(f => `<li class="text-truncate" style="font-size: 11px;">• ${f.name}</li>`).join('')}</ul>`;
        } else {
          info.classList.add('d-none');
          info.innerHTML = '';
        }
      });
    }
  </script>

  <style>
    .max-w-200 {
      max-w: 200px;
    }
    .max-w-350 {
      max-w: 350px;
    }
    @media (min-width: 768px) {
      .max-w-200 {
        max-w: 400px;
      }
    }
    .select-files-box:hover .upload-icon {
      color: #7c3aed !important;
    }
    .select-files-box:hover {
      border-color: rgba(124, 58, 237, 0.4) !important;
      background-color: rgba(15, 23, 42, 0.4) !important;
    }
    .focus-outline-none:focus {
      outline: none !important;
      box-shadow: none !important;
    }
  </style>

</body>
</html>
