<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Configurações - Black Bird Media Center</title>
</head>
<body class="bg-dark text-light min-vh-screen">

  <%- include('header') %>

  <!-- Modal de Upload (Necessário por estar no header.ejs) (Bootstrap 5) -->
  <div class="modal fade animate" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content modal-content-premium border-0">
        <!-- Modal Header -->
        <div class="modal-header modal-header-premium border-0">
          <h5 class="modal-title font-outfit fw-bold text-white" id="uploadModalLabel">Upload de Arquivos</h5>
          <button type="button" class="btn-close btn-close-white" onclick="toggleUploadModal()" aria-label="Close"></button>
        </div>
        <!-- Modal Body -->
        <div class="modal-body p-4">
          <input type="hidden" id="currentPath" value="">
          <label class="d-flex flex-column align-items-center justify-content-center w-100 border border-secondary border-dashed rounded-3 cursor-pointer p-4 bg-dark bg-opacity-25 hover-bg-dark transition-all-200 select-files-box" style="height: 176px; border-style: dashed !important; border-width: 2px !important; border-color: rgba(255,255,255,0.1) !important;">
            <div class="d-flex flex-column align-items-center justify-content-center text-center">
              <i class="bi bi-cloud-arrow-up text-secondary fs-1 mb-2 upload-icon"></i>
              <p class="mb-1 text-light fw-bold small">Selecione arquivos para upload</p>
              <p class="text-secondary small mb-0" style="font-size: 11px;">Mídia enviada ficará disponível na raiz</p>
            </div>
            <input type="file" id="fileInput" class="d-none" multiple>
          </label>
          <div id="selectedFilesInfo" class="small text-secondary mt-3 p-3 rounded bg-dark bg-opacity-50 border border-secondary border-opacity-10 d-none" style="max-height: 110px; overflow-y: auto;"></div>
        </div>
        <!-- Modal Footer -->
        <div class="modal-footer modal-footer-premium border-0">
          <button type="button" class="btn btn-premium-secondary" onclick="toggleUploadModal()">Cancelar</button>
          <button type="button" class="btn btn-premium-primary border-0" id="uploadFilesBtn">Enviar</button>
        </div>
      </div>
    </div>
  </div>

  <div class="container-xl py-4 px-3">
    
    <!-- Título -->
    <div class="mb-4">
      <h2 class="fs-4 fw-bold text-white font-outfit m-0"><%= t('general_settings') %></h2>
      <p class="text-secondary small m-0 mt-1"><%= t('manage_security') %></p>
    </div>

    <!-- Container de Configurações -->
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        
        <div class="card border border-secondary border-opacity-10 shadow-lg" style="background-color: rgba(15, 23, 42, 0.45); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
          <div class="card-header border-bottom border-secondary border-opacity-10 bg-transparent py-3 px-4">
            <h5 class="card-title font-outfit fw-semibold text-white m-0 d-flex align-items-center gap-2">
              <i class="bi bi-sliders text-gradient"></i>
              <%= t('server_parameters') %>
            </h5>
          </div>

          <div class="card-body p-4">
            
            <% if (typeof successMsg !== 'undefined' && successMsg) { %>
              <div class="alert alert-success py-2 px-3 small border-0 mb-4" style="background-color: rgba(25, 135, 84, 0.15); color: #75b798;">
                <i class="bi bi-check-circle-fill me-2"></i> <%= t('settings_saved_success') %>
              </div>
            <% } %>

            <form action="/settings/save" method="POST">
              
              <!-- Configuração de Autenticação -->
              <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-10">
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div>
                    <label class="form-label text-white fw-semibold mb-1" style="font-size: 15px;"><%= t('enable_auth') %></label>
                    <p class="text-secondary small mb-0"><%= t('enable_auth_desc') %></p>
                  </div>
                  <div class="form-check form-switch m-0 fs-5">
                    <input class="form-check-input cursor-pointer" type="checkbox" name="authEnabled" id="authEnabled" value="true" <%= config.authEnabled ? 'checked' : '' %>>
                  </div>
                </div>
              </div>

              <!-- Senha de Login -->
              <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-10" id="passwordSection">
                <label for="loginPassword" class="form-label text-white fw-semibold mb-1" style="font-size: 15px;"><%= t('login_password') %></label>
                <p class="text-secondary small mb-3"><%- t('login_password_desc') %></p>
                
                <div class="position-relative" style="max-width: 400px;">
                  <input type="password" id="loginPassword" name="loginPassword" value="<%= config.loginPassword %>" placeholder="••••••••" required class="form-control input-premium pe-5">
                  <button type="button" onclick="togglePasswordVisibility()" class="btn btn-link position-absolute end-0 top-50 translate-y-middle text-secondary hover-text-white border-0 py-0 px-3" style="margin-top: -20px;">
                    <i class="bi bi-eye-slash" id="togglePasswordIcon"></i>
                  </button>
                </div>
              </div>

              <!-- Arquivos Permitidos para Upload -->
              <div class="mb-4 pb-2">
                <label for="allowedExtensions" class="form-label text-white fw-semibold mb-1" style="font-size: 15px;"><%= t('allowed_extensions') %></label>
                <p class="text-secondary small mb-3"><%= t('allowed_extensions_desc') %></p>
                
                <input type="text" id="allowedExtensions" name="allowedExtensions" value="<%= config.allowedExtensions %>" placeholder="Ex: .mp4, .mp3, .jpg, .png, .mkv, .avi" required class="form-control input-premium mb-2">
                
                <div class="d-flex flex-wrap gap-1.5 mt-2">
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.mp4')">.mp4</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.mkv')">.mkv</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.mp3')">.mp3</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.jpg')">.jpg</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.png')">.png</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="appendExtension('.pdf')">.pdf</span>
                  <span class="badge bg-secondary bg-opacity-25 border border-secondary border-opacity-10 text-secondary cursor-pointer hover-bg-secondary transition-all-200" onclick="resetExtensions()">Restaurar Padrão</span>
                </div>
              </div>

              <!-- Endereço Personalizado da Aplicação -->
              <div class="mb-4 pb-2 border-top border-secondary border-opacity-10 pt-4">
                <label for="appAddress" class="form-label text-white fw-semibold mb-1" style="font-size: 15px;"><%= t('app_address') %></label>
                <p class="text-secondary small mb-3"><%= t('app_address_desc') %></p>
                
                <input type="text" id="appAddress" name="appAddress" value="<%= config.appAddress || '' %>" placeholder="Ex: http://192.168.1.100:5555" class="form-control input-premium mb-2" style="max-width: 400px;">
              </div>

              <!-- Idioma do Sistema -->
              <div class="mb-4 pb-2 border-top border-secondary border-opacity-10 pt-4">
                <label for="language" class="form-label text-white fw-semibold mb-1" style="font-size: 15px;"><%= t('language') %></label>
                <p class="text-secondary small mb-3"><%= t('language_desc') %></p>
                
                <select id="language" name="language" class="form-select form-control input-premium pe-5" style="max-width: 400px; background-color: rgba(15, 23, 42, 0.45);">
                  <option value="en" <%= config.language === 'en' ? 'selected' : '' %>>English</option>
                  <option value="pt" <%= config.language === 'pt' ? 'selected' : '' %>>Português</option>
                  <option value="es" <%= config.language === 'es' ? 'selected' : '' %>>Español</option>
                </select>
              </div>

              <!-- Botões de Ação -->
              <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top border-secondary border-opacity-10">
                <a href="/" class="btn btn-premium-secondary px-4"><%= t('cancel') %></a>
                <button type="submit" class="btn btn-premium-primary border-0 px-4"><%= t('save_settings') %></button>
              </div>

            </form>

          </div>
        </div>

        <!-- Card de Backup e Restauração -->
        <div class="card card-premium p-4 mt-4 animate-fade-in">
          <div class="card-body">
            
            <!-- Título -->
            <div class="mb-4">
              <h2 class="fs-4 fw-bold text-white font-outfit m-0"><%= t('backup_restore') %></h2>
              <p class="text-secondary small m-0 mt-1"><%= t('backup_restore_desc') %></p>
            </div>

            <div class="row g-4 pt-3 border-top border-secondary border-opacity-10">
              
              <!-- Seção de Exportar -->
              <div class="col-md-6 border-end border-secondary border-opacity-10 pe-md-4">
                <h5 class="text-white fw-semibold mb-2" style="font-size: 16px;"><%= t('export_backup') %></h5>
                <p class="text-secondary small mb-4">Faça o download de todas as configurações, favoritos, câmeras e históricos salvos em um único arquivo de backup JSON.</p>
                <a href="/settings/export" class="btn btn-premium-primary border-0 px-4 py-2 text-decoration-none d-inline-flex align-items-center gap-2">
                  <i class="bi bi-download"></i>
                  <span><%= t('export_backup') %></span>
                </a>
              </div>

              <!-- Seção de Importar -->
              <div class="col-md-6 ps-md-4">
                <h5 class="text-white fw-semibold mb-2" style="font-size: 16px;"><%= t('import_backup') %></h5>
                <p class="text-secondary small mb-3">Restaurar configurações e bases de dados a partir de um arquivo de backup JSON previamente exportado.</p>
                
                <form action="/settings/import" method="POST" enctype="multipart/form-data">
                  <div class="mb-3">
                    <label for="backupFile" class="form-label text-secondary small mb-1.5"><%= t('select_backup_file') %></label>
                    <input type="file" id="backupFile" name="backupFile" accept=".json" required class="form-control input-premium py-1.5">
                  </div>
                  <button type="submit" class="btn btn-premium-secondary px-4 py-2 border-0 d-inline-flex align-items-center gap-2">
                    <i class="bi bi-upload"></i>
                    <span><%= t('import_backup') %></span>
                  </button>
                </form>
              </div>

            </div>

          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- JS assets -->
  <script src="/js/bootstrap.bundle.min.js"></script>
  <script src="/js/sweetalert2.all.min.js"></script>
  <script src="/js/scripts.js"></script>

  <script>
    // Monitoramento do Input de Upload (para compatibilidade com header)
    const fileInput = document.getElementById('fileInput');
    if (fileInput) {
      fileInput.addEventListener('change', function(e) {
        const info = document.getElementById('selectedFilesInfo');
        if (this.files && this.files.length > 0) {
          info.classList.remove('d-none');
          info.innerHTML = `<strong>Selecionados (${this.files.length}):</strong><ul class="list-unstyled mt-1 mb-0">${Array.from(this.files).map(f => `<li class="text-truncate" style="font-size: 11px;">• ${f.name}</li>`).join('')}</ul>`;
        } else {
          info.classList.add('d-none');
          info.innerHTML = '';
        }
      });
    }

    // Toggle de visibilidade da senha
    function togglePasswordVisibility() {
      const passwordInput = document.getElementById('loginPassword');
      const icon = document.getElementById('togglePasswordIcon');
      if (passwordInput.type === 'password') {
        passwordInput.type = 'text';
        icon.classList.remove('bi-eye-slash');
        icon.classList.add('bi-eye');
      } else {
        passwordInput.type = 'password';
        icon.classList.remove('bi-eye');
        icon.classList.add('bi-eye-slash');
      }
    }

    // Adiciona extensão sugerida se não existir
    function appendExtension(ext) {
      const input = document.getElementById('allowedExtensions');
      const val = input.value.trim();
      let parts = val ? val.split(',').map(x => x.trim()) : [];
      
      if (!parts.includes(ext) && !parts.includes(ext.replace('.', ''))) {
        parts.push(ext);
        input.value = parts.join(', ');
      }
    }

    // Reseta para as extensões padrão
    function resetExtensions() {
      document.getElementById('allowedExtensions').value = '.mp4, .mp3, .jpg, .png, .mkv, .avi, .jpeg, .gif, .wav';
    }
  </script>

  <style>
    .select-files-box:hover .upload-icon {
      color: #7c3aed !important;
    }
    .select-files-box:hover {
      border-color: rgba(124, 58, 237, 0.4) !important;
      background-color: rgba(15, 23, 42, 0.4) !important;
    }
    .translate-y-middle {
      transform: translateY(-50%);
    }
  </style>

</body>
</html>
